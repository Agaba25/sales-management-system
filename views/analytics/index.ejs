<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/brand.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/app-pages.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>
  <body class="dashboard-page">
    <nav class="navbar navbar-expand-lg dashboard-nav">
      <div class="container">
        <%- include('../partials/brand-mark') %>
        <div class="d-flex align-items-center gap-2 gap-md-3">
          <a href="/" class="btn btn-outline-secondary btn-sm d-none d-sm-inline-flex">
            <i class="bi bi-house me-1"></i>Dashboard
          </a>
          <div class="user-pill">
            <span class="user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></span>
            <span>
              <span class="user-name d-block"><%= currentUser.name %></span>
              <span class="user-role"><%= currentUser.role %></span>
            </span>
          </div>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="app-page-main">
      <div class="container">
        <div class="dashboard-back">
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
            <i class="bi bi-arrow-left me-1"></i>Back
          </button>
        </div>

        <div class="page-hero">
          <span class="page-hero-badge"><i class="bi bi-bar-chart-line"></i> Data Insights</span>
          <h1>Analytics</h1>
          <p>Explore sales trends, inventory movements, customer behaviour, and team performance.</p>
        </div>

        <div class="filter-panel">
          <p class="filter-panel-label">Data Category</p>
          <div class="type-tabs">
            <% const types = [
              { value: 'sales', label: 'Sales' },
              { value: 'inventory', label: 'Inventory' },
              { value: 'procurement', label: 'Procurement' },
              { value: 'customers', label: 'Customers' },
              { value: 'performance', label: 'Performance' }
            ]; %>
            <% types.forEach((t) => {
              if (t.value === 'performance' && currentUser.role === 'SALESPERSON') return;
            %>
              <a href="/analytics?type=<%= t.value %>&period=<%= period %>&refDate=<%= refDate %>&search=<%= encodeURIComponent(filters.search || '') %>"
                 class="type-tab<%= type === t.value ? ' active' : '' %>"><%= t.label %></a>
            <% }) %>
          </div>

          <p class="filter-panel-label mt-3">Time Period</p>
          <div class="period-tabs">
            <a href="/analytics?type=<%= type %>&period=day&refDate=<%= refDate %>&search=<%= encodeURIComponent(filters.search || '') %>"
               class="period-tab<%= period === 'day' ? ' active' : '' %>">Today</a>
            <a href="/analytics?type=<%= type %>&period=week&refDate=<%= refDate %>&search=<%= encodeURIComponent(filters.search || '') %>"
               class="period-tab<%= period === 'week' ? ' active' : '' %>">This Week</a>
            <a href="/analytics?type=<%= type %>&period=month&refDate=<%= refDate %>&search=<%= encodeURIComponent(filters.search || '') %>"
               class="period-tab<%= period === 'month' ? ' active' : '' %>">This Month</a>
          </div>

          <div class="range-chip">
            <i class="bi bi-calendar3"></i> <%= rangeLabel %>
          </div>

          <form method="GET" action="/analytics" class="row g-2 align-items-end">
            <input type="hidden" name="type" value="<%= type %>">
            <input type="hidden" name="period" value="<%= period %>">
            <div class="col-md-3 col-6">
              <label class="form-label small text-muted mb-1">Reference date</label>
              <input type="date" name="refDate" class="form-control form-control-sm" value="<%= refDate %>">
            </div>
            <div class="col-md-5 col-6">
              <label class="form-label small text-muted mb-1">Search</label>
              <input type="search" name="search" class="form-control form-control-sm" placeholder="Filter results…" value="<%= filters.search || '' %>">
            </div>
            <div class="col-md-2 col-6">
              <button type="submit" class="btn btn-primary btn-sm w-100">
                <i class="bi bi-funnel me-1"></i>Apply
              </button>
            </div>
            <div class="col-md-2 col-6">
              <a href="/analytics/export/csv?type=<%= type %>&period=<%= period %>&refDate=<%= refDate %>&startDate=<%= filters.startDate %>&endDate=<%= filters.endDate %>&search=<%= encodeURIComponent(filters.search || '') %>"
                 class="btn btn-outline-primary btn-sm w-100">
                <i class="bi bi-download me-1"></i>CSV
              </a>
            </div>
          </form>
        </div>

        <div class="row g-3 insight-grid">
          <% if (type === 'sales') { %>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Total Sales</p>
                <p class="insight-card-value"><%= summary.totalSales || 0 %></p>
                <p class="insight-card-hint">Transactions in period</p>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Revenue</p>
                <p class="insight-card-value" style="font-size:1.1rem">UGX <%= formatCurrencyUGX(summary.totalRevenue || 0) %></p>
                <p class="insight-card-hint">Gross sales value</p>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Avg. Sale</p>
                <p class="insight-card-value" style="font-size:1.1rem">UGX <%= formatCurrencyUGX(summary.averageSale || 0) %></p>
                <p class="insight-card-hint">Per transaction</p>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Items Sold</p>
                <p class="insight-card-value"><%= summary.totalItems || 0 %></p>
                <p class="insight-card-hint">Total units moved</p>
              </div>
            </div>
          <% } else if (type === 'inventory') { %>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Movements</p>
                <p class="insight-card-value"><%= summary.movementCount || 0 %></p>
                <p class="insight-card-hint">Stock changes logged</p>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Stock In</p>
                <p class="insight-card-value"><%= summary.stockIn || 0 %></p>
                <p class="insight-card-hint">Units received</p>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Stock Out</p>
                <p class="insight-card-value"><%= summary.stockOut || 0 %></p>
                <p class="insight-card-hint">Units dispatched</p>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Stock Value</p>
                <p class="insight-card-value" style="font-size:1.1rem">UGX <%= formatCurrencyUGX(summary.stockValue || 0) %></p>
                <p class="insight-card-hint">Current inventory worth</p>
              </div>
            </div>
          <% } else if (type === 'customers') { %>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Customers</p>
                <p class="insight-card-value"><%= summary.totalCustomers || 0 %></p>
                <p class="insight-card-hint">Total registered</p>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Active Buyers</p>
                <p class="insight-card-value"><%= summary.activeCustomers || 0 %></p>
                <p class="insight-card-hint">With orders in period</p>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Orders</p>
                <p class="insight-card-value"><%= summary.totalOrders || 0 %></p>
                <p class="insight-card-hint">Customer purchases</p>
              </div>
            </div>
            <div class="col-md-3 col-6">
              <div class="insight-card">
                <p class="insight-card-label">Customer Revenue</p>
                <p class="insight-card-value" style="font-size:1.1rem">UGX <%= formatCurrencyUGX(summary.customerRevenue || 0) %></p>
                <p class="insight-card-hint">Total spend in period</p>
              </div>
            </div>
          <% } else if (type === 'performance') { %>
            <div class="col-md-4">
              <div class="insight-card">
                <p class="insight-card-label">Team Members</p>
                <p class="insight-card-value"><%= rows.length %></p>
                <p class="insight-card-hint">Salespeople tracked</p>
              </div>
            </div>
            <div class="col-md-4">
              <div class="insight-card">
                <p class="insight-card-label">Top Performer</p>
                <p class="insight-card-value" style="font-size:1rem"><%= rows[0]?.name || '—' %></p>
                <p class="insight-card-hint">Highest revenue in period</p>
              </div>
            </div>
            <div class="col-md-4">
              <div class="insight-card">
                <p class="insight-card-label">Top Revenue</p>
                <p class="insight-card-value" style="font-size:1.1rem">UGX <%= formatCurrencyUGX(rows[0]?.revenue || 0) %></p>
                <p class="insight-card-hint">Best individual result</p>
              </div>
            </div>
          <% } else { %>
            <div class="col-md-4">
              <div class="insight-card">
                <p class="insight-card-label">Procurement Entries</p>
                <p class="insight-card-value"><%= rows.length %></p>
                <p class="insight-card-hint">Purchase records in period</p>
              </div>
            </div>
            <div class="col-md-4">
              <div class="insight-card">
                <p class="insight-card-label">Total Rows</p>
                <p class="insight-card-value"><%= pagination.totalRows || rows.length %></p>
                <p class="insight-card-hint">Matching your filters</p>
              </div>
            </div>
            <div class="col-md-4">
              <div class="insight-card">
                <p class="insight-card-label">Date Range</p>
                <p class="insight-card-value" style="font-size:0.95rem"><%= rangeLabel %></p>
                <p class="insight-card-hint">Current view window</p>
              </div>
            </div>
          <% } %>
        </div>

        <% if (chart && chart.length) { %>
          <div class="chart-card">
            <p class="chart-card-title">
              <i class="bi bi-graph-up me-1"></i>
              <%= type === 'sales' ? 'Daily Revenue Trend' : type === 'performance' ? 'Revenue by Salesperson' : 'Distribution' %>
            </p>
            <canvas id="analyticsChart" height="90"></canvas>
          </div>
        <% } %>

        <div class="data-card">
          <div class="data-card-header">
            <h2 class="data-card-title">
              <i class="bi bi-table me-2 text-secondary"></i>
              <%= type.charAt(0).toUpperCase() + type.slice(1) %> Details
            </h2>
            <span class="text-muted small"><%= pagination.totalRows || rows.length %> record<%= (pagination.totalRows || rows.length) === 1 ? '' : 's' %></span>
          </div>
          <div class="table-responsive">
            <table class="table dashboard-table mb-0">
              <thead>
                <tr>
                  <% if (type === 'sales') { %>
                    <th>Sale ID</th>
                    <th>Customer</th>
                    <th>Salesperson</th>
                    <th class="text-end">Amount</th>
                    <th class="text-end">Items</th>
                    <th>Date</th>
                  <% } else if (type === 'inventory' || type === 'procurement') { %>
                    <th>Product</th>
                    <th>SKU</th>
                    <th class="text-end">Qty</th>
                    <th>Date</th>
                    <th>Recorded By</th>
                  <% } else if (type === 'customers') { %>
                    <th>Customer</th>
                    <th>Email</th>
                    <th class="text-end">Orders</th>
                    <th class="text-end">Total Spent</th>
                  <% } else if (type === 'performance') { %>
                    <th>Salesperson</th>
                    <th class="text-end">Sales Count</th>
                    <th class="text-end">Revenue</th>
                  <% } %>
                </tr>
              </thead>
              <tbody>
                <% if (!rows || rows.length === 0) { %>
                  <tr><td colspan="8" class="dashboard-empty py-4">No data for the selected period and filters.</td></tr>
                <% } %>

                <% rows.forEach((r) => { %>
                  <tr>
                    <% if (type === 'sales') { %>
                      <td><span class="entity-tag">#<%= r.id %></span></td>
                      <td class="fw-semibold"><%= r.customer_name %></td>
                      <td><%= r.salesperson_name || '—' %></td>
                      <td class="text-end">UGX <%= formatCurrencyUGX(r.total_amount || 0) %></td>
                      <td class="text-end"><%= r.item_count %></td>
                      <td><%= new Date(r.created_at).toLocaleString('en-GB') %></td>
                    <% } else if (type === 'inventory' || type === 'procurement') { %>
                      <td class="fw-semibold"><%= r.product_name || r.name %></td>
                      <td><code class="text-secondary"><%= r.sku || '—' %></code></td>
                      <td class="text-end"><%= r.quantity || r.qty_sold || 0 %></td>
                      <td><%= r.created_at ? new Date(r.created_at).toLocaleString('en-GB') : '—' %></td>
                      <td><%= r.recorded_by || r.logged_by || '—' %></td>
                    <% } else if (type === 'customers') { %>
                      <td class="fw-semibold"><%= r.name %></td>
                      <td><%= r.email || '—' %></td>
                      <td class="text-end"><%= r.order_count %></td>
                      <td class="text-end">UGX <%= formatCurrencyUGX(r.total_spent || 0) %></td>
                    <% } else if (type === 'performance') { %>
                      <td class="fw-semibold"><%= r.name %></td>
                      <td class="text-end"><%= r.sales_count %></td>
                      <td class="text-end">UGX <%= formatCurrencyUGX(r.revenue || 0) %></td>
                    <% } %>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/app-footer') %>

    <script>
      (function () {
        try {
          const chartData = <%- JSON.stringify(chart || []) %>;
          const chartType = <%- JSON.stringify(type) %>;
          const ctx = document.getElementById('analyticsChart');
          if (!ctx || !window.Chart || !chartData.length) return;

          const labels = chartData.map((c) => c.label);
          const values = chartData.map((c) => c.value);

          new Chart(ctx, {
            type: chartType === 'performance' ? 'bar' : 'line',
            data: {
              labels,
              datasets: [{
                label: chartType === 'sales' ? 'Revenue (UGX)' : 'Value',
                data: values,
                backgroundColor: chartType === 'performance'
                  ? 'rgba(30, 58, 95, 0.75)'
                  : 'rgba(14, 165, 233, 0.15)',
                borderColor: '#0ea5e9',
                borderWidth: 2,
                fill: chartType !== 'performance',
                tension: 0.35,
              }],
            },
            options: {
              responsive: true,
              plugins: {
                legend: { display: false },
              },
              scales: {
                y: { beginAtZero: true, grid: { color: '#f1f5f9' } },
                x: { grid: { display: false } },
              },
            },
          });
        } catch (e) {
          console.error(e);
        }
      })();
    </script>
  </body>
</html>
