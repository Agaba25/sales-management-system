<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="/css/brand.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
      <div class="container">
        <%- include('../partials/brand-mark') %>
        <div class="d-flex align-items-center gap-3">
          <a href="/customers" class="btn btn-outline-primary btn-sm">Customers</a>
          <span class="text-secondary small"><%= currentUser.name %> · <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-5">
      <div class="mb-3">
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">Back</button>
      </div>

      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Analytics</h1>
        <form class="d-flex gap-2" method="GET" action="/analytics">
          <select name="type" class="form-select form-select-sm">
            <option value="sales" <%= type === 'sales' ? 'selected' : '' %>>Sales</option>
            <option value="inventory" <%= type === 'inventory' ? 'selected' : '' %>>Inventory</option>
            <option value="procurement" <%= type === 'procurement' ? 'selected' : '' %>>Procurement</option>
            <option value="customers" <%= type === 'customers' ? 'selected' : '' %>>Customers</option>
            <option value="performance" <%= type === 'performance' ? 'selected' : '' %>>Performance</option>
          </select>
          <select name="period" class="form-select form-select-sm">
            <option value="day">Day</option>
            <option value="week">Week</option>
            <option value="month" selected>Month</option>
          </select>
          <input type="search" name="search" class="form-control form-control-sm" placeholder="Search" value="<%= filters.search || '' %>">
          <button class="btn btn-primary btn-sm" type="submit">Filter</button>
        </form>
      </div>

      <div class="mb-4">
        <div class="row g-3">
          <div class="col-md-3">
            <div class="card p-3">
              <div class="text-muted small">Rows</div>
              <div class="fw-semibold h4"><%= pagination.totalRows || rows.length || 0 %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card p-3">
              <div class="text-muted small">Limit</div>
              <div class="fw-semibold h4"><%= pagination.limit || filters.limit %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card p-3">
              <div class="text-muted small">From</div>
              <div class="fw-semibold h5"><%= filters.startDate %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card p-3">
              <div class="text-muted small">To</div>
              <div class="fw-semibold h5"><%= filters.endDate %></div>
            </div>
          </div>
        </div>
      </div>

      <div class="mb-3 d-flex gap-2">
        <a href="/analytics/export/csv?type=<%= type %>&startDate=<%= filters.startDate %>&endDate=<%= filters.endDate %>&search=<%= filters.search || '' %>" class="btn btn-outline-primary btn-sm">Export CSV</a>
        <a href="/analytics/export/pdf?type=<%= type %>&startDate=<%= filters.startDate %>&endDate=<%= filters.endDate %>&search=<%= filters.search || '' %>" class="btn btn-outline-secondary btn-sm">Export PDF</a>
      </div>

      <div class="card mb-4">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <% if (type === 'sales') { %>
                    <th>Sale ID</th>
                    <th>Customer</th>
                    <th>Salesperson</th>
                    <th class="text-end">Amount</th>
                    <th class="text-end">Items</th>
                    <th>Date</th>
                  <% } else if (type === 'inventory' || type === 'procurement') { %>
                    <th>Product</th>
                    <th>SKU</th>
                    <th class="text-end">Qty</th>
                    <th>Date</th>
                    <th>Recorded By</th>
                  <% } else if (type === 'customers') { %>
                    <th>Customer</th>
                    <th>Email</th>
                    <th class="text-end">Orders</th>
                    <th class="text-end">Total Spent</th>
                  <% } else if (type === 'performance') { %>
                    <th>Salesperson</th>
                    <th class="text-end">Sales Count</th>
                    <th class="text-end">Revenue</th>
                  <% } %>
                </tr>
              </thead>
              <tbody>
                <% if (!rows || rows.length === 0) { %>
                  <tr><td colspan="8" class="text-center text-muted py-4">No data for selected filters.</td></tr>
                <% } %>

                <% rows.forEach((r) => { %>
                  <tr>
                    <% if (type === 'sales') { %>
                      <td><%= r.id %></td>
                      <td><%= r.customer_name %></td>
                      <td><%= r.salesperson_name %></td>
                      <td class="text-end">UGX <%= formatCurrencyUGX(r.total_amount || 0) %></td>
                      <td class="text-end"><%= r.item_count %></td>
                      <td><%= new Date(r.created_at).toLocaleString() %></td>
                    <% } else if (type === 'inventory' || type === 'procurement') { %>
                      <td><%= r.product_name || r.name %></td>
                      <td><%= r.sku || '-' %></td>
                      <td class="text-end"><%= r.quantity || r.qty_sold || 0 %></td>
                      <td><%= r.created_at ? new Date(r.created_at).toLocaleString() : '' %></td>
                      <td><%= r.recorded_by || r.logged_by || '-' %></td>
                    <% } else if (type === 'customers') { %>
                      <td><%= r.name %></td>
                      <td><%= r.email %></td>
                      <td class="text-end"><%= r.order_count %></td>
                      <td class="text-end">UGX <%= formatCurrencyUGX(r.total_spent || 0) %></td>
                    <% } else if (type === 'performance') { %>
                      <td><%= r.name %></td>
                      <td class="text-end"><%= r.sales_count %></td>
                      <td class="text-end">UGX <%= formatCurrencyUGX(r.revenue || 0) %></td>
                    <% } %>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card p-3">
        <canvas id="analyticsChart" height="80"></canvas>
      </div>

    </main>

    <script>
      (function(){
        try {
          const chartData = <%- JSON.stringify(chart || []) %>;
          const labels = chartData.map(c => c.label);
          const values = chartData.map(c => c.value);
          const ctx = document.getElementById('analyticsChart');
          if (ctx && window.Chart) {
            new Chart(ctx, { type: 'bar', data: { labels, datasets: [{ label: 'Value', data: values, backgroundColor: 'rgba(13,110,253,0.7)' }] }, options: { responsive: true } });
          }
        } catch(e) { console.error(e); }
      })();
    </script>
  </body>
</html>
