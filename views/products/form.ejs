<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand" href="/">Sales Management System</a>
        <div class="d-flex align-items-center gap-3">
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="mb-3">
        <a href="/products" class="btn btn-outline-secondary btn-sm">Back to Products</a>
      </div>

      <div class="bg-white border rounded p-4">
        <h1 class="h4 mb-4"><%= title %></h1>

        <% if (errorMessages && errorMessages.length) { %>
          <div class="alert alert-danger"><%= errorMessages[0] %></div>
        <% } %>

        <form action="<%= action %>" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label for="name" class="form-label">Product Name</label>
              <input id="name" name="name" class="form-control" value="<%= product.name || '' %>" required>
            </div>

            <div class="col-md-6">
              <label for="sku" class="form-label">SKU</label>
              <input id="sku" name="sku" class="form-control" value="<%= product.sku || '' %>" required>
            </div>

            <div class="col-md-6">
              <label for="category_name" class="form-label">Category</label>
              <input
                id="category_name"
                name="category_name"
                class="form-control"
                list="category-options"
                value="<%= product.category_name || '' %>"
                placeholder="Type or choose a category"
              >
              <datalist id="category-options">
                <% categories.forEach((category) => { %>
                  <option value="<%= category.name %>"></option>
                <% }) %>
              </datalist>
              <div class="form-text">Leave blank to keep the product uncategorized.</div>
            </div>

            <div class="col-md-6">
              <label for="quantity" class="form-label">Quantity</label>
              <input id="quantity" name="quantity" type="number" min="0" class="form-control" value="<%= product.quantity ?? 0 %>" required>
            </div>

            <div class="col-md-4">
              <label for="unit_price" class="form-label">Unit Price (UGX)</label>
              <input id="unit_price" name="unit_price" type="number" min="0" step="0.01" class="form-control" value="<%= product.unit_price ?? 0 %>" required>
            </div>

            <div class="col-md-4">
              <label for="cost_price" class="form-label">Cost Price (UGX)</label>
              <input id="cost_price" name="cost_price" type="number" min="0" step="0.01" class="form-control" value="<%= product.cost_price ?? 0 %>" required>
            </div>

            <div class="col-md-4">
              <label for="reorder_level" class="form-label">Reorder Level</label>
              <input id="reorder_level" name="reorder_level" type="number" min="0" class="form-control" value="<%= product.reorder_level ?? 5 %>" required>
            </div>

            <div class="col-12">
              <label for="description" class="form-label">Description</label>
              <textarea id="description" name="description" class="form-control" rows="3"><%= product.description || '' %></textarea>
            </div>

            <div class="col-12">
              <div class="form-check">
                <input
                  id="is_active"
                  name="is_active"
                  type="checkbox"
                  class="form-check-input"
                  <%= product.is_active === false ? '' : 'checked' %>
                >
                <label for="is_active" class="form-check-label">Active product</label>
              </div>
            </div>
          </div>

          <div class="mt-4">
            <button type="submit" class="btn btn-primary">Save Product</button>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>
