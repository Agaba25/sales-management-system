<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%- include('../partials/google-analytics') %>
    <title><%= title %> | <%= appName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/brand.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/app-pages.css">
  </head>
  <body class="dashboard-page">
    <% const navLinks = !availableOnly
      ? [{ href: '/inventory', label: 'Inventory', icon: 'bi-boxes', btnClass: 'btn-outline-secondary btn-sm' }]
      : []; %>
    <%- include('../partials/app-navbar', { navLinks }) %>

    <main class="app-page-main">
      <div class="container">
        <div class="dashboard-back">
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
            <i class="bi bi-arrow-left me-1"></i>Back
          </button>
        </div>

        <% const activeCount = products.filter(p => p.is_active).length;
           const availableCount = products.filter(p => p.quantity > 0).length;
           const lowCount = products.filter(p => p.quantity > 0 && p.quantity <= (p.reorder_level || 5)).length;
        %>

        <div class="page-hero">
          <span class="page-hero-badge"><i class="bi bi-tags"></i> Product Catalog</span>
          <h1><%= availableOnly ? 'Available Products' : 'Products' %></h1>
          <p>
            <% if (availableOnly) { %>
              Browse in-stock items ready for sale — prices and quantities at a glance.
            <% } else { %>
              Manage your full product catalog — pricing, categories, stock levels, and availability.
            <% } %>
          </p>
        </div>

        <% if (errorMessages && errorMessages.length) { %>
          <div class="alert alert-danger"><%= errorMessages[0] %></div>
        <% } %>
        <% if (successMessages && successMessages.length) { %>
          <div class="alert alert-success"><%= successMessages[0] %></div>
        <% } %>

        <div class="row g-3 insight-grid">
          <div class="col-6 col-lg-3">
            <div class="insight-card">
              <p class="insight-card-label">Total Products</p>
              <p class="insight-card-value"><%= products.length %></p>
              <p class="insight-card-hint"><%= availableOnly ? 'Available to sell' : 'In catalog' %></p>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="insight-card">
              <p class="insight-card-label">In Stock</p>
              <p class="insight-card-value"><%= availableCount %></p>
              <p class="insight-card-hint">Quantity &gt; 0</p>
            </div>
          </div>
          <% if (!availableOnly) { %>
            <div class="col-6 col-lg-3">
              <div class="insight-card">
                <p class="insight-card-label">Active</p>
                <p class="insight-card-value"><%= activeCount %></p>
                <p class="insight-card-hint">Listed for sale</p>
              </div>
            </div>
            <div class="col-6 col-lg-3">
              <div class="insight-card">
                <p class="insight-card-label">Low Stock</p>
                <p class="insight-card-value"><%= lowCount %></p>
                <p class="insight-card-hint">Needs restocking</p>
              </div>
            </div>
          <% } %>
        </div>

        <div class="filter-panel">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
            <p class="filter-panel-label mb-0">Search Products</p>
            <% if (currentUser.role === 'CEO' || currentUser.role === 'MANAGER') { %>
              <a href="/products/new" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Add Product
              </a>
            <% } %>
          </div>
          <form action="/products" method="GET" class="row g-2 align-items-end">
            <div class="col-md-10">
              <input type="search" name="search" value="<%= search %>" class="form-control form-control-sm" placeholder="Search by name, SKU, or category…">
            </div>
            <div class="col-md-2">
              <button type="submit" class="btn btn-primary btn-sm w-100">
                <i class="bi bi-search me-1"></i>Search
              </button>
            </div>
          </form>
        </div>

        <div class="data-card">
          <div class="data-card-header">
            <h2 class="data-card-title">
              <i class="bi bi-grid me-2 text-secondary"></i>Product List
            </h2>
            <span class="text-muted small"><%= products.length %> product<%= products.length === 1 ? '' : 's' %></span>
          </div>
          <div class="table-responsive">
            <table class="table dashboard-table mb-0">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>SKU</th>
                  <th>Category</th>
                  <th class="text-center">Qty</th>
                  <th class="text-end">Unit Price</th>
                  <th>Status</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (products.length === 0) { %>
                  <tr>
                    <td colspan="7" class="dashboard-empty py-4">No products match your search.</td>
                  </tr>
                <% } %>

                <% products.forEach((product) => { %>
                  <tr>
                    <td class="product-name-cell"><%= product.name %></td>
                    <td><code class="text-secondary"><%= product.sku %></code></td>
                    <td><%= product.category_name || 'Uncategorized' %></td>
                    <td class="text-center">
                      <span class="stock-qty<%= product.quantity === 0 ? ' stock-qty--out' : (product.quantity <= (product.reorder_level || 5) ? ' stock-qty--low' : '') %>">
                        <%= product.quantity %>
                      </span>
                    </td>
                    <td class="text-end price-cell">UGX <%= formatCurrencyUGX(product.unit_price) %></td>
                    <td>
                      <% if (product.is_active) { %>
                        <span class="status-pill status-pill--active"><i class="bi bi-check-circle"></i> Active</span>
                      <% } else { %>
                        <span class="status-pill status-pill--inactive">Inactive</span>
                      <% } %>
                    </td>
                    <td class="text-end">
                      <% if (currentUser.role === 'CEO' || currentUser.role === 'MANAGER') { %>
                        <div class="table-actions">
                          <a href="/products/<%= product.id %>/edit" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-pencil"></i> Edit
                          </a>
                          <% if (currentUser.role === 'CEO') { %>
                            <form action="/products/<%= product.id %>/delete" method="POST" class="d-inline">
                              <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i>
                              </button>
                            </form>
                          <% } %>
                        </div>
                      <% } else { %>
                        <span class="text-muted small"><i class="bi bi-eye me-1"></i>View only</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/app-footer') %>
  </body>
</html>
