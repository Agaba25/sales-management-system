<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand" href="/">Sales Management System</a>
        <div class="d-flex align-items-center gap-3">
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
        <h1 class="h3 mb-0"><%= availableOnly ? 'Available Products' : 'Products' %></h1>
        <% if (currentUser.role === 'CEO' || currentUser.role === 'MANAGER') { %>
          <a href="/products/new" class="btn btn-primary">Add Product</a>
        <% } %>
      </div>

      <% if (errorMessages && errorMessages.length) { %>
        <div class="alert alert-danger"><%= errorMessages[0] %></div>
      <% } %>
      <% if (successMessages && successMessages.length) { %>
        <div class="alert alert-success"><%= successMessages[0] %></div>
      <% } %>

      <form action="/products" method="GET" class="row g-2 mb-3">
        <div class="col-md-10">
          <input
            type="search"
            name="search"
            value="<%= search %>"
            class="form-control"
            placeholder="Search by product, SKU, or category"
          >
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-outline-primary w-100">Search</button>
        </div>
      </form>

      <div class="table-responsive bg-white border rounded">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>SKU</th>
              <th>Category</th>
              <th>Quantity</th>
              <th>Unit Price (UGX)</th>
              <th>Status</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (products.length === 0) { %>
              <tr>
                <td colspan="7" class="text-center text-secondary py-4">No products found.</td>
              </tr>
            <% } %>

            <% products.forEach((product) => { %>
              <tr>
                <td><%= product.name %></td>
                <td><%= product.sku %></td>
                <td><%= product.category_name || 'Uncategorized' %></td>
                <td><%= formatNumber(product.quantity) %></td>
                <td>UGX <%= formatCurrencyUGX(product.unit_price) %></td>
                <td>
                  <% if (product.is_active) { %>
                    <span class="badge text-bg-success">Active</span>
                  <% } else { %>
                    <span class="badge text-bg-secondary">Inactive</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <% if (currentUser.role === 'CEO' || currentUser.role === 'MANAGER') { %>
                    <a href="/products/<%= product.id %>/edit" class="btn btn-outline-primary btn-sm">Edit</a>
                  <% } %>
                  <% if (currentUser.role === 'CEO') { %>
                    <form action="/products/<%= product.id %>/delete" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                    </form>
                  <% } %>
                  <% if (currentUser.role === 'SALESPERSON') { %>
                    <span class="text-secondary small">View only</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </body>
</html>
