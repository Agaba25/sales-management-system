<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <span class="navbar-brand mb-0 h1">CEO Dashboard</span>
        <div class="d-flex align-items-center gap-3">
          <a href="/activity" class="btn btn-outline-secondary btn-sm">Activity</a>
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-5">
      <div class="mb-3">
        <a href="/users" class="btn btn-primary">Manage Staff</a>
        <a href="/products" class="btn btn-primary">Manage Products</a>
        <a href="/inventory" class="btn btn-outline-primary">Inventory</a>
        <a href="/sales" class="btn btn-outline-primary">Sales</a>
        <a href="/customers" class="btn btn-outline-primary">Customers</a>
        <a href="/reports" class="btn btn-outline-primary">Reports</a>
        <a href="/analytics" class="btn btn-outline-primary">Analytics</a>
      </div>
      <div class="row g-3">
        <div class="col-md-4">
          <div class="card border-0 shadow-sm">
            <div class="card-body">
              <p class="text-secondary mb-1">Total Products</p>
              <h2 class="h3 mb-0"><%= formatNumber(totalProducts) %></h2>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm">
            <div class="card-body">
              <p class="text-secondary mb-1">Total Sales</p>
              <h2 class="h3 mb-0"><%= formatNumber(totalSales) %></h2>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm">
            <div class="card-body">
              <p class="text-secondary mb-1">Total Users</p>
              <h2 class="h3 mb-0"><%= formatNumber(totalUsers) %></h2>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-0 shadow-sm">
            <div class="card-body">
              <p class="text-secondary mb-1">Tracked Actions</p>
              <h2 class="h3 mb-0"><%= formatNumber(totalActivities) %></h2>
            </div>
          </div>
        </div>
      </div>
    </main>
  </body>
</html>
