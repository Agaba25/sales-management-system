<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
      rel="stylesheet"
    >
    <link rel="stylesheet" href="/css/brand.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/pos.css">
  </head>
  <body class="dashboard-page">
    <%- include('../partials/app-navbar') %>

    <main class="dashboard-main">
      <div class="container">
        <div class="dashboard-back">
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
            <i class="bi bi-arrow-left me-1"></i>Back
          </button>
        </div>

        <div class="dashboard-welcome">
          <span class="dashboard-role-badge"><i class="bi bi-person-badge"></i> Salesperson</span>
          <h1>Welcome back, <%= currentUser.name.split(' ')[0] %></h1>
          <p>Record sales fast with Quick Sale, manage customers, and check product availability.</p>
        </div>

        <div class="dashboard-pos-banner">
          <div>
            <h2><i class="bi bi-lightning-charge-fill me-1"></i> Customers waiting? Use Quick Sale</h2>
            <p>Search products instantly, pick customers in one click, and complete sales without leaving the screen.</p>
          </div>
          <a href="/sales/new" class="btn btn-lg">
            <i class="bi bi-cart-plus me-1"></i> Start Quick Sale
          </a>
        </div>

        <p class="dashboard-section-title">Quick Actions</p>
        <div class="dashboard-actions">
          <a href="/sales/new" class="dashboard-action dashboard-action--featured">
            <span class="dashboard-action-icon dashboard-action-icon--success">
              <i class="bi bi-lightning-charge"></i>
            </span>
            <span class="dashboard-action-label">Quick Sale</span>
            <span class="dashboard-action-desc">Fast checkout — search &amp; sell</span>
          </a>
          <a href="/sales" class="dashboard-action">
            <span class="dashboard-action-icon dashboard-action-icon--primary">
              <i class="bi bi-receipt"></i>
            </span>
            <span class="dashboard-action-label">My Sales</span>
            <span class="dashboard-action-desc">View your transactions</span>
          </a>
          <a href="/customers/new" class="dashboard-action">
            <span class="dashboard-action-icon dashboard-action-icon--info">
              <i class="bi bi-person-plus"></i>
            </span>
            <span class="dashboard-action-label">Add Customer</span>
            <span class="dashboard-action-desc">Register a new client</span>
          </a>
          <a href="/products" class="dashboard-action">
            <span class="dashboard-action-icon dashboard-action-icon--neutral">
              <i class="bi bi-box-seam"></i>
            </span>
            <span class="dashboard-action-label">Products</span>
            <span class="dashboard-action-desc">Browse available stock</span>
          </a>
        </div>

        <div class="row g-3 dashboard-stats">
          <div class="col-md-4">
            <div class="dashboard-stat">
              <span class="dashboard-stat-icon dashboard-stat-icon--accent">
                <i class="bi bi-graph-up-arrow"></i>
              </span>
              <div>
                <p class="dashboard-stat-label">My Sales</p>
                <p class="dashboard-stat-value"><%= mySales %></p>
                <p class="dashboard-stat-hint">Total transactions recorded</p>
              </div>
            </div>
          </div>
          <div class="col-md-8">
            <div class="dashboard-card h-100">
              <div class="dashboard-card-header">
                <h2 class="dashboard-card-title">
                  <i class="bi bi-box-seam me-2 text-secondary"></i>Available Products
                </h2>
                <a href="/products" class="btn btn-sm btn-outline-primary">View all</a>
              </div>
              <div class="dashboard-card-body">
                <% if (products && products.length) { %>
                  <div class="table-responsive">
                    <table class="table dashboard-table mb-0">
                      <thead>
                        <tr>
                          <th>Product</th>
                          <th>SKU</th>
                          <th>Price (UGX)</th>
                          <th>Qty</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% products.forEach((p) => { %>
                          <tr>
                            <td class="fw-semibold"><%= p.name %></td>
                            <td><code class="text-secondary"><%= p.sku %></code></td>
                            <td><%= formatCurrencyUGX(p.unit_price) %></td>
                            <td>
                              <span class="qty-badge<%= p.quantity <= 5 ? ' qty-badge--low' : '' %>">
                                <%= p.quantity %>
                              </span>
                            </td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                <% } else { %>
                  <p class="dashboard-empty mb-0">
                    <i class="bi bi-inbox d-block mb-2 fs-4"></i>
                    No products available at the moment.
                  </p>
                <% } %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/app-footer') %>
  </body>
</html>
