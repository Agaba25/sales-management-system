<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand" href="/">Sales Management System</a>
        <div class="d-flex align-items-center gap-3">
          <a href="/customers" class="btn btn-outline-primary btn-sm">Customers</a>
          <a href="/sales" class="btn btn-outline-secondary btn-sm">Sales</a>
          <a href="/inventory" class="btn btn-outline-secondary btn-sm">Inventory</a>
          <a href="/products" class="btn btn-outline-secondary btn-sm">Products</a>
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="mb-3">
        <a href="/customers" class="btn btn-outline-secondary btn-sm">Back to Customers</a>
      </div>

      <div class="bg-white border rounded p-4">
        <h1 class="h4 mb-4"><%= title %></h1>

        <% if (errorMessages && errorMessages.length) { %>
          <div class="alert alert-danger"><%= errorMessages[0] %></div>
        <% } %>

        <form action="<%= action %>" method="POST">
          <div class="row g-3">
            <div class="col-md-6">
              <label for="name" class="form-label">Name</label>
              <input id="name" name="name" class="form-control" value="<%= customer.name || '' %>" required>
            </div>

            <div class="col-md-6">
              <label for="email" class="form-label">Email</label>
              <input id="email" name="email" type="email" class="form-control" value="<%= customer.email || '' %>">
            </div>

            <div class="col-md-6">
              <label for="phone" class="form-label">Phone</label>
              <input id="phone" name="phone" class="form-control" value="<%= customer.phone || '' %>">
            </div>

            <div class="col-md-6">
              <label for="address" class="form-label">Address</label>
              <input id="address" name="address" class="form-control" value="<%= customer.address || '' %>">
            </div>

            <div class="col-12">
              <div class="form-check">
                <input
                  id="is_active"
                  name="is_active"
                  type="checkbox"
                  class="form-check-input"
                  <%= customer.is_active === false ? '' : 'checked' %>
                >
                <label for="is_active" class="form-check-label">Active customer</label>
              </div>
            </div>
          </div>

          <div class="mt-4">
            <button type="submit" class="btn btn-primary">Save Customer</button>
          </div>
        </form>
      </div>
    </main>
  </body>
</html>
