<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/brand.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/app-pages.css">
  </head>
  <body class="dashboard-page">
    <nav class="navbar navbar-expand-lg dashboard-nav">
      <div class="container">
        <%- include('../partials/brand-mark') %>
        <div class="d-flex align-items-center gap-2 gap-md-3">
          <a href="/sales" class="btn btn-outline-primary btn-sm d-none d-sm-inline-flex">
            <i class="bi bi-receipt me-1"></i>Sales
          </a>
          <div class="user-pill">
            <span class="user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></span>
            <span>
              <span class="user-name d-block"><%= currentUser.name %></span>
              <span class="user-role"><%= currentUser.role %></span>
            </span>
          </div>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="app-page-main">
      <div class="container">
        <div class="dashboard-back">
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
            <i class="bi bi-arrow-left me-1"></i>Back
          </button>
        </div>

        <% const activeCount = customers.filter(c => c.is_active).length;
           const withEmail = customers.filter(c => c.email).length;
           const withPhone = customers.filter(c => c.phone).length;
           const canEdit = currentUser.role === 'CEO' || currentUser.role === 'MANAGER';
        %>

        <div class="page-hero">
          <span class="page-hero-badge"><i class="bi bi-people"></i> Client Directory</span>
          <h1>Customers</h1>
          <p>Maintain your client list — link customers to sales and keep contact details up to date.</p>
        </div>

        <% if (errorMessages && errorMessages.length) { %>
          <div class="alert alert-danger"><%= errorMessages[0] %></div>
        <% } %>
        <% if (successMessages && successMessages.length) { %>
          <div class="alert alert-success"><%= successMessages[0] %></div>
        <% } %>

        <div class="row g-3 insight-grid">
          <div class="col-6 col-lg-3">
            <div class="insight-card">
              <p class="insight-card-label">Total Customers</p>
              <p class="insight-card-value"><%= customers.length %></p>
              <p class="insight-card-hint">In directory</p>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="insight-card">
              <p class="insight-card-label">Active</p>
              <p class="insight-card-value"><%= activeCount %></p>
              <p class="insight-card-hint">Available for sales</p>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="insight-card">
              <p class="insight-card-label">With Email</p>
              <p class="insight-card-value"><%= withEmail %></p>
              <p class="insight-card-hint">Contact on file</p>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="insight-card">
              <p class="insight-card-label">With Phone</p>
              <p class="insight-card-value"><%= withPhone %></p>
              <p class="insight-card-hint">Reachable by call</p>
            </div>
          </div>
        </div>

        <div class="filter-panel">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-0">
            <p class="filter-panel-label mb-0">Customer List</p>
            <a href="/customers/new" class="btn btn-primary btn-sm">
              <i class="bi bi-person-plus me-1"></i>Add Customer
            </a>
          </div>
        </div>

        <div class="data-card">
          <div class="data-card-header">
            <h2 class="data-card-title">
              <i class="bi bi-person-lines-fill me-2 text-secondary"></i>All Customers
            </h2>
            <span class="text-muted small"><%= customers.length %> client<%= customers.length === 1 ? '' : 's' %></span>
          </div>
          <div class="table-responsive">
            <table class="table dashboard-table mb-0">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Status</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (customers.length === 0) { %>
                  <tr>
                    <td colspan="6" class="dashboard-empty py-4">
                      No customers yet.
                      <a href="/customers/new" class="d-block mt-2">Add your first customer</a>
                    </td>
                  </tr>
                <% } %>

                <% customers.forEach((customer) => { %>
                  <tr>
                    <td><span class="entity-tag">#<%= customer.id %></span></td>
                    <td class="product-name-cell"><%= customer.name %></td>
                    <td>
                      <% if (customer.email) { %>
                        <a href="mailto:<%= customer.email %>" class="text-decoration-none"><%= customer.email %></a>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (customer.phone) { %>
                        <a href="tel:<%= customer.phone %>" class="text-decoration-none"><%= customer.phone %></a>
                      <% } else { %>
                        <span class="text-muted">—</span>
                      <% } %>
                    </td>
                    <td>
                      <% if (customer.is_active) { %>
                        <span class="status-pill status-pill--active"><i class="bi bi-check-circle"></i> Active</span>
                      <% } else { %>
                        <span class="status-pill status-pill--inactive">Inactive</span>
                      <% } %>
                    </td>
                    <td class="text-end">
                      <% if (canEdit) { %>
                        <div class="table-actions">
                          <a href="/customers/<%= customer.id %>/edit" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-pencil"></i> Edit
                          </a>
                          <% if (currentUser.role === 'CEO') { %>
                            <form action="/customers/<%= customer.id %>/delete" method="POST" class="d-inline">
                              <button type="submit" class="btn btn-outline-danger btn-sm">
                                <i class="bi bi-trash"></i>
                              </button>
                            </form>
                          <% } %>
                        </div>
                      <% } else { %>
                        <span class="text-muted small"><i class="bi bi-eye me-1"></i>View only</span>
                      <% } %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/app-footer') %>
  </body>
</html>
