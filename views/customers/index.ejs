<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
    <link rel="stylesheet" href="/css/brand.css">
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <%- include('../partials/brand-mark') %>
        <div class="d-flex align-items-center gap-3">
          <a href="/sales" class="btn btn-outline-primary btn-sm">Sales</a>
          <a href="/inventory" class="btn btn-outline-secondary btn-sm">Inventory</a>
          <a href="/products" class="btn btn-outline-secondary btn-sm">Products</a>
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="mb-3">
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">Back</button>
      </div>

      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <h1 class="h3 mb-1">Customers</h1>
          <p class="text-secondary mb-0">Manage customers used for sales.</p>
        </div>
        <a href="/customers/new" class="btn btn-primary">Add Customer</a>
      </div>

      <% if (errorMessages && errorMessages.length) { %>
        <div class="alert alert-danger"><%= errorMessages[0] %></div>
      <% } %>
      <% if (successMessages && successMessages.length) { %>
        <div class="alert alert-success"><%= successMessages[0] %></div>
      <% } %>

      <div class="table-responsive bg-white border rounded">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Name</th>
              <th>Email</th>
              <th>Phone</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (customers.length === 0) { %>
              <tr>
                <td colspan="6" class="text-center text-secondary py-4">No customers found.</td>
              </tr>
            <% } %>

            <% customers.forEach((customer) => { %>
              <tr>
                <td><%= customer.id %></td>
                <td><%= customer.name %></td>
                <td><%= customer.email || '-' %></td>
                <td><%= customer.phone || '-' %></td>
                <td><%= customer.is_active ? 'Active' : 'Inactive' %></td>
                <td>
                  <% if (currentUser.role === 'CEO' || currentUser.role === 'MANAGER') { %>
                    <a href="/customers/<%= customer.id %>/edit" class="btn btn-sm btn-outline-secondary me-2">Edit</a>
                  <% } %>
                  <% if (currentUser.role === 'CEO') { %>
                    <form action="/customers/<%= customer.id %>/delete" method="POST" class="d-inline">
                      <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                  <% } %>
                  <% if (currentUser.role === 'SALESPERSON') { %>
                    <span class="text-secondary small">Read only</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </body>
</html>
