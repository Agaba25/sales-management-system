<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand" href="/">Sales Management System</a>
        <div class="d-flex align-items-center gap-3">
          <a href="/activity" class="btn btn-outline-secondary btn-sm">Activity</a>
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="mb-3">
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">Back</button>
      </div>

      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <h1 class="h3 mb-1">Staff Users</h1>
          <p class="text-secondary mb-0">Create staff accounts and assign system roles.</p>
        </div>
        <a href="/users/new" class="btn btn-primary">Add User</a>
      </div>

      <% if (errorMessages && errorMessages.length) { %>
        <div class="alert alert-danger"><%= errorMessages[0] %></div>
      <% } %>
      <% if (successMessages && successMessages.length) { %>
        <div class="alert alert-success"><%= successMessages[0] %></div>
      <% } %>

      <div class="table-responsive bg-white border rounded">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Name</th>
              <th>Email</th>
              <th>Role</th>
              <th>Created</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (users.length === 0) { %>
              <tr>
                <td colspan="5" class="text-center text-secondary py-4">No users found.</td>
              </tr>
            <% } %>

            <% users.forEach((user) => { %>
              <tr>
                <td><%= user.name %></td>
                <td><%= user.email %></td>
                <td><span class="badge text-bg-secondary"><%= user.role %></span></td>
                <td><%= new Date(user.created_at).toLocaleString() %></td>
                <td class="text-end">
                  <a href="/users/<%= user.id %>/edit" class="btn btn-outline-primary btn-sm">Edit</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </body>
</html>
