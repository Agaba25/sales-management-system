<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/brand.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/app-pages.css">
  </head>
  <body class="dashboard-page">
    <% const navLinks = [{ href: '/activity', label: 'Activity', icon: 'bi-clock-history', btnClass: 'btn-outline-secondary btn-sm' }]; %>
    <%- include('../partials/app-navbar', { navLinks }) %>

    <main class="app-page-main">
      <div class="container">
        <div class="dashboard-back">
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
            <i class="bi bi-arrow-left me-1"></i>Back
          </button>
        </div>

        <% const ceoCount = users.filter(u => u.role === 'CEO').length;
           const managerCount = users.filter(u => u.role === 'MANAGER').length;
           const salespersonCount = users.filter(u => u.role === 'SALESPERSON').length;
        %>

        <div class="page-hero">
          <span class="page-hero-badge"><i class="bi bi-person-gear"></i> Team Administration</span>
          <h1>Manage Staff</h1>
          <p>Create staff accounts, assign roles, and control who can access each part of the system.</p>
        </div>

        <% if (errorMessages && errorMessages.length) { %>
          <div class="alert alert-danger"><%= errorMessages[0] %></div>
        <% } %>
        <% if (successMessages && successMessages.length) { %>
          <div class="alert alert-success"><%= successMessages[0] %></div>
        <% } %>

        <div class="row g-3 insight-grid">
          <div class="col-6 col-lg-3">
            <div class="insight-card">
              <p class="insight-card-label">Total Staff</p>
              <p class="insight-card-value"><%= users.length %></p>
              <p class="insight-card-hint">Registered accounts</p>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="insight-card">
              <p class="insight-card-label">Executives</p>
              <p class="insight-card-value"><%= ceoCount %></p>
              <p class="insight-card-hint">CEO role</p>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="insight-card">
              <p class="insight-card-label">Managers</p>
              <p class="insight-card-value"><%= managerCount %></p>
              <p class="insight-card-hint">Operations leads</p>
            </div>
          </div>
          <div class="col-6 col-lg-3">
            <div class="insight-card">
              <p class="insight-card-label">Salespeople</p>
              <p class="insight-card-value"><%= salespersonCount %></p>
              <p class="insight-card-hint">Front-line staff</p>
            </div>
          </div>
        </div>

        <div class="filter-panel">
          <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-0">
            <p class="filter-panel-label mb-0">Staff Directory</p>
            <a href="/users/new" class="btn btn-primary btn-sm">
              <i class="bi bi-person-plus me-1"></i>Add User
            </a>
          </div>
        </div>

        <div class="data-card">
          <div class="data-card-header">
            <h2 class="data-card-title">
              <i class="bi bi-people me-2 text-secondary"></i>All Users
            </h2>
            <span class="text-muted small"><%= users.length %> member<%= users.length === 1 ? '' : 's' %></span>
          </div>
          <div class="table-responsive">
            <table class="table dashboard-table mb-0">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Role</th>
                  <th>Joined</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% if (users.length === 0) { %>
                  <tr>
                    <td colspan="5" class="dashboard-empty py-4">No staff accounts yet. Add your first team member.</td>
                  </tr>
                <% } %>

                <% users.forEach((user) => { %>
                  <tr>
                    <td>
                      <div class="d-flex align-items-center gap-2">
                        <span class="user-avatar" style="width:32px;height:32px;font-size:0.75rem;"><%= user.name.charAt(0).toUpperCase() %></span>
                        <span class="product-name-cell"><%= user.name %></span>
                      </div>
                    </td>
                    <td><a href="mailto:<%= user.email %>" class="text-decoration-none"><%= user.email %></a></td>
                    <td><span class="role-badge role-badge--<%= user.role %>"><%= user.role %></span></td>
                    <td class="text-muted"><%= new Date(user.created_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) %></td>
                    <td class="text-end">
                      <div class="table-actions">
                        <a href="/users/<%= user.id %>/edit" class="btn btn-outline-primary btn-sm">
                          <i class="bi bi-pencil"></i> Edit
                        </a>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/app-footer') %>
  </body>
</html>
