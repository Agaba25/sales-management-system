<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/brand.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/app-pages.css">
  </head>
  <body class="dashboard-page">
    <nav class="navbar navbar-expand-lg dashboard-nav">
      <div class="container">
        <%- include('../partials/brand-mark') %>
        <div class="d-flex align-items-center gap-2 gap-md-3">
          <a href="/" class="btn btn-outline-secondary btn-sm d-none d-sm-inline-flex">
            <i class="bi bi-house me-1"></i>Dashboard
          </a>
          <div class="user-pill">
            <span class="user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></span>
            <span>
              <span class="user-name d-block"><%= currentUser.name %></span>
              <span class="user-role"><%= currentUser.role %></span>
            </span>
          </div>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="app-page-main">
      <div class="container">
        <div class="dashboard-back">
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
            <i class="bi bi-arrow-left me-1"></i>Back
          </button>
        </div>

        <div class="page-hero">
          <span class="page-hero-badge"><i class="bi bi-clock-history"></i> Audit Trail</span>
          <h1>Activity Log</h1>
          <p>Review system actions by staff — filter by time period, role, or action type.</p>
        </div>

        <% if (errorMessages && errorMessages.length) { %>
          <div class="alert alert-danger"><%= errorMessages[0] %></div>
        <% } %>

        <div class="filter-panel">
          <p class="filter-panel-label">Time Period</p>
          <div class="period-tabs">
            <a href="/activity?period=day&refDate=<%= refDate %>&action=<%= action %>&role=<%= role %>&search=<%= encodeURIComponent(search) %>"
               class="period-tab<%= period === 'day' ? ' active' : '' %>">
              Today <span class="count"><%= periodCounts.day %></span>
            </a>
            <a href="/activity?period=week&refDate=<%= refDate %>&action=<%= action %>&role=<%= role %>&search=<%= encodeURIComponent(search) %>"
               class="period-tab<%= period === 'week' ? ' active' : '' %>">
              This Week <span class="count"><%= periodCounts.week %></span>
            </a>
            <a href="/activity?period=month&refDate=<%= refDate %>&action=<%= action %>&role=<%= role %>&search=<%= encodeURIComponent(search) %>"
               class="period-tab<%= period === 'month' ? ' active' : '' %>">
              This Month <span class="count"><%= periodCounts.month %></span>
            </a>
          </div>

          <div class="range-chip">
            <i class="bi bi-calendar3"></i> Showing: <%= rangeLabel %>
          </div>

          <form method="GET" action="/activity" class="row g-2 align-items-end">
            <input type="hidden" name="period" value="<%= period %>">
            <div class="col-md-3 col-6">
              <label class="form-label small text-muted mb-1">Reference date</label>
              <input type="date" name="refDate" class="form-control form-control-sm" value="<%= refDate %>">
            </div>
            <div class="col-md-3 col-6">
              <label class="form-label small text-muted mb-1">Action type</label>
              <select name="action" class="form-select form-select-sm">
                <option value="">All actions</option>
                <% actions.forEach((a) => { %>
                  <option value="<%= a %>"<%= action === a ? ' selected' : '' %>><%= a %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-2 col-6">
              <label class="form-label small text-muted mb-1">Role</label>
              <select name="role" class="form-select form-select-sm">
                <option value="">All roles</option>
                <option value="CEO"<%= role === 'CEO' ? ' selected' : '' %>>CEO</option>
                <option value="MANAGER"<%= role === 'MANAGER' ? ' selected' : '' %>>Manager</option>
                <option value="SALESPERSON"<%= role === 'SALESPERSON' ? ' selected' : '' %>>Salesperson</option>
              </select>
            </div>
            <div class="col-md-3 col-6">
              <label class="form-label small text-muted mb-1">Search</label>
              <input type="search" name="search" class="form-control form-control-sm" placeholder="Actor, action, description…" value="<%= search %>">
            </div>
            <div class="col-md-1 col-12">
              <button type="submit" class="btn btn-primary btn-sm w-100">
                <i class="bi bi-funnel me-1"></i>Filter
              </button>
            </div>
          </form>
        </div>

        <div class="row g-3 insight-grid">
          <div class="col-md-4">
            <div class="insight-card">
              <p class="insight-card-label">Results in period</p>
              <p class="insight-card-value"><%= activities.length %></p>
              <p class="insight-card-hint">Activities matching your filters</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="insight-card">
              <p class="insight-card-label">Today</p>
              <p class="insight-card-value"><%= periodCounts.day %></p>
              <p class="insight-card-hint">Actions logged today</p>
            </div>
          </div>
          <div class="col-md-4">
            <div class="insight-card">
              <p class="insight-card-label">This month</p>
              <p class="insight-card-value"><%= periodCounts.month %></p>
              <p class="insight-card-hint">Actions logged this month</p>
            </div>
          </div>
        </div>

        <% if (!groupedActivities.length) { %>
          <div class="data-card">
            <p class="dashboard-empty py-5 mb-0">
              <i class="bi bi-inbox d-block mb-2 fs-3"></i>
              No activity recorded for the selected period.
            </p>
          </div>
        <% } else { %>
          <% groupedActivities.forEach((group) => { %>
            <section class="activity-group">
              <div class="activity-group-header">
                <i class="bi bi-calendar-event"></i>
                <%= group.heading %>
                <span class="activity-group-count"><%= group.items.length %> event<%= group.items.length === 1 ? '' : 's' %></span>
              </div>

              <% group.items.forEach((activity) => { %>
                <article class="activity-item">
                  <span class="activity-icon"><i class="bi bi-lightning"></i></span>
                  <div class="activity-meta">
                    <div class="activity-action">
                      <span class="action-badge"><%= activity.action %></span>
                    </div>
                    <p class="activity-desc mb-0"><%= activity.description %></p>
                    <div class="activity-actor mt-1">
                      <span><i class="bi bi-person me-1"></i><%= activity.user_name || activity.user_email || 'Unknown' %></span>
                      <span class="role-badge role-badge--<%= activity.role %>"><%= activity.role %></span>
                      <% if (activity.entity_type) { %>
                        <span class="entity-tag"><%= activity.entity_type %> #<%= activity.entity_id %></span>
                      <% } %>
                    </div>
                  </div>
                  <time class="activity-time">
                    <%= new Date(activity.created_at).toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit' }) %>
                  </time>
                </article>
              <% }) %>
            </section>
          <% }) %>
        <% } %>
      </div>
    </main>

    <%- include('../partials/app-footer') %>
  </body>
</html>
