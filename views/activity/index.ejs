<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
    <link rel="stylesheet" href="/css/brand.css">
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <%- include('../partials/brand-mark') %>
        <div class="d-flex align-items-center gap-3">
          <a href="/activity" class="btn btn-outline-primary btn-sm">Activity</a>
          <a href="/sales" class="btn btn-outline-secondary btn-sm">Sales</a>
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="mb-3">
        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">Back</button>
      </div>

      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <h1 class="h3 mb-1">Activity Log</h1>
          <p class="text-secondary mb-0">Track actions executed by salespeople and managers.</p>
        </div>
      </div>

      <% if (errorMessages && errorMessages.length) { %>
        <div class="alert alert-danger"><%= errorMessages[0] %></div>
      <% } %>

      <div class="table-responsive bg-white border rounded">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Actor</th>
              <th>Role</th>
              <th>Action</th>
              <th>Description</th>
              <th>Target</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody>
            <% if (activities.length === 0) { %>
              <tr>
                <td colspan="7" class="text-center text-secondary py-4">No activity recorded yet.</td>
              </tr>
            <% } %>

            <% activities.forEach((activity) => { %>
              <tr>
                <td><%= activity.id %></td>
                <td><%= activity.user_name || activity.user_email || 'Unknown' %></td>
                <td><%= activity.role %></td>
                <td><%= activity.action %></td>
                <td><%= activity.description %></td>
                <td><%= activity.entity_type ? `${activity.entity_type} #${activity.entity_id}` : '-' %></td>
                <td><%= new Date(activity.created_at).toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </body>
</html>
