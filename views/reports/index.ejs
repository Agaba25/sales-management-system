<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/brand.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/app-pages.css">
  </head>
  <body class="dashboard-page">
    <nav class="navbar navbar-expand-lg dashboard-nav">
      <div class="container">
        <%- include('../partials/brand-mark') %>
        <div class="d-flex align-items-center gap-2 gap-md-3">
          <a href="/" class="btn btn-outline-secondary btn-sm d-none d-sm-inline-flex">
            <i class="bi bi-house me-1"></i>Dashboard
          </a>
          <div class="user-pill">
            <span class="user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></span>
            <span>
              <span class="user-name d-block"><%= currentUser.name %></span>
              <span class="user-role"><%= currentUser.role %></span>
            </span>
          </div>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="app-page-main">
      <div class="container">
        <div class="dashboard-back">
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
            <i class="bi bi-arrow-left me-1"></i>Back
          </button>
        </div>

        <div class="page-hero">
          <span class="page-hero-badge"><i class="bi bi-file-earmark-bar-graph"></i> Business Reports</span>
          <h1>Sales Reports</h1>
          <p>Product-level sales performance with revenue, cost, and margin analysis for any period.</p>
        </div>

        <div class="filter-panel">
          <p class="filter-panel-label">Report Period</p>
          <div class="period-tabs">
            <a href="/reports?period=day&refDate=<%= refDate %>" class="period-tab<%= period === 'day' ? ' active' : '' %>">
              <i class="bi bi-sun"></i> Today
            </a>
            <a href="/reports?period=week&refDate=<%= refDate %>" class="period-tab<%= period === 'week' ? ' active' : '' %>">
              <i class="bi bi-calendar-week"></i> This Week
            </a>
            <a href="/reports?period=month&refDate=<%= refDate %>" class="period-tab<%= period === 'month' ? ' active' : '' %>">
              <i class="bi bi-calendar-month"></i> This Month
            </a>
          </div>

          <div class="range-chip">
            <i class="bi bi-calendar3"></i> <%= rangeLabel %>
          </div>

          <form method="GET" action="/reports" class="row g-2 align-items-end">
            <input type="hidden" name="period" value="<%= period %>">
            <div class="col-md-4 col-8">
              <label class="form-label small text-muted mb-1">Reference date</label>
              <input type="date" name="refDate" class="form-control form-control-sm" value="<%= refDate %>">
            </div>
            <div class="col-md-2 col-4">
              <button type="submit" class="btn btn-primary btn-sm w-100">
                <i class="bi bi-arrow-repeat me-1"></i>Apply
              </button>
            </div>
          </form>
        </div>

        <div class="row g-3 insight-grid">
          <div class="col-md-3 col-6">
            <div class="insight-card">
              <p class="insight-card-label">Period Revenue</p>
              <p class="insight-card-value">UGX <%= formatCurrencyUGX(periodStats.revenue) %></p>
              <p class="insight-card-hint">Sales in selected range</p>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="insight-card">
              <p class="insight-card-label">Units Sold</p>
              <p class="insight-card-value"><%= periodStats.units %></p>
              <p class="insight-card-hint">Total quantity moved</p>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="insight-card">
              <p class="insight-card-label">Products Sold</p>
              <p class="insight-card-value"><%= periodStats.productsSold %></p>
              <p class="insight-card-hint">SKUs with sales activity</p>
            </div>
          </div>
          <div class="col-md-3 col-6">
            <div class="insight-card">
              <p class="insight-card-label">Low Stock Items</p>
              <p class="insight-card-value"><%= summary.lowStock || 0 %></p>
              <p class="insight-card-hint">At or below reorder level</p>
            </div>
          </div>
        </div>

        <div class="data-card">
          <div class="data-card-header">
            <h2 class="data-card-title">
              <i class="bi bi-table me-2 text-secondary"></i>Product Sales Breakdown
            </h2>
            <span class="text-muted small"><%= rows.length %> product<%= rows.length === 1 ? '' : 's' %> listed</span>
          </div>
          <div class="table-responsive">
            <table class="table dashboard-table mb-0">
              <thead>
                <tr>
                  <th>Product</th>
                  <th>SKU</th>
                  <th class="text-end">Units Sold</th>
                  <th class="text-end">Revenue</th>
                  <th class="text-end">Cost Price</th>
                  <th class="text-end">Total Cost</th>
                  <th class="text-end">Margin</th>
                  <th class="text-center">Met Cost</th>
                </tr>
              </thead>
              <tbody>
                <% if (!rows || rows.length === 0) { %>
                  <tr>
                    <td colspan="8" class="dashboard-empty py-4">No sales recorded in the selected period.</td>
                  </tr>
                <% } %>

                <% rows.forEach((r) => { %>
                  <% const units = Number(r.units_sold || 0); %>
                  <% const revenue = Number(r.sales_value || 0); %>
                  <% const costPrice = Number(r.cost_price || 0); %>
                  <% const totalCost = units * costPrice; %>
                  <% const margin = revenue - totalCost; %>
                  <tr>
                    <td class="fw-semibold"><%= r.name || r.product_name || '-' %></td>
                    <td><code class="text-secondary"><%= r.sku || '-' %></code></td>
                    <td class="text-end"><%= units %></td>
                    <td class="text-end">UGX <%= formatCurrencyUGX(revenue) %></td>
                    <td class="text-end">UGX <%= formatCurrencyUGX(costPrice) %></td>
                    <td class="text-end">UGX <%= formatCurrencyUGX(totalCost) %></td>
                    <td class="text-end <%= margin >= 0 ? 'margin-positive' : 'margin-negative' %>">
                      UGX <%= formatCurrencyUGX(margin) %>
                    </td>
                    <td class="text-center">
                      <% if (units === 0) { %>
                        <span class="text-muted">—</span>
                      <% } else if (totalCost <= revenue) { %>
                        <span class="text-success"><i class="bi bi-check-circle-fill"></i></span>
                      <% } else { %>
                        <span class="text-danger"><i class="bi bi-x-circle-fill"></i></span>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/app-footer') %>
  </body>
</html>
