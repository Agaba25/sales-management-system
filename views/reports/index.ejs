<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
      <div class="container">
        <a class="navbar-brand mb-0 h1" href="/">Sales Management System</a>
        <div class="d-flex align-items-center gap-3">
          <a href="/customers" class="btn btn-outline-primary btn-sm">Customers</a>
          <span class="text-secondary small"><%= currentUser.name %> · <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-5">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3">Reports</h1>
        <form class="d-flex gap-2" method="GET" action="/reports">
          <select name="period" class="form-select form-select-sm">
            <option value="day" <%= period === 'day' ? 'selected' : '' %>>Day</option>
            <option value="week" <%= period === 'week' ? 'selected' : '' %>>Week</option>
            <option value="month" <%= period === 'month' ? 'selected' : '' %>>Month</option>
          </select>
          <button class="btn btn-primary btn-sm" type="submit">Refresh</button>
        </form>
      </div>

      <div class="mb-4">
        <div class="row g-3">
          <div class="col-md-3">
            <div class="card p-3">
              <div class="text-muted small">Products</div>
              <div class="fw-semibold h4"><%= formatNumber(summary.totalProducts || 0) %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card p-3">
              <div class="text-muted small">Total Revenue</div>
              <div class="fw-semibold h4">UGX <%= formatCurrencyUGX(summary.retailValue || 0) %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card p-3">
              <div class="text-muted small">Low stock</div>
              <div class="fw-semibold h4"><%= formatNumber(summary.lowStock || 0) %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="card p-3">
              <div class="text-muted small">Out of stock</div>
              <div class="fw-semibold h4"><%= formatNumber(summary.outOfStock || 0) %></div>
            </div>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th>Product</th>
                  <th>SKU</th>
                  <th class="text-end">Units Sold</th>
                  <th class="text-end">Revenue</th>
                  <th class="text-end">Cost Price</th>
                  <th class="text-end">Total Cost</th>
                  <th class="text-end">Margin</th>
                  <th class="text-center">Met Cost</th>
                </tr>
              </thead>
              <tbody>
                <% if (!rows || rows.length === 0) { %>
                  <tr><td colspan="8" class="text-center text-muted py-4">No sales in selected period.</td></tr>
                <% } %>

                <% rows.forEach((r) => { %>
                  <% const units = Number(r.units_sold || r.units_sold || 0); %>
                  <% const revenue = Number(r.sales_value || r.sales_value || 0); %>
                  <% const costPrice = Number(r.cost_price || 0); %>
                  <% const totalCost = units * costPrice; %>
                  <% const margin = revenue - totalCost; %>
                <tr>
                  <td><%= r.name || r.product_name || '-' %></td>
                  <td><%= r.sku || '-' %></td>
                  <td class="text-end"><%= formatNumber(units) %></td>
                  <td class="text-end">UGX <%= formatCurrencyUGX(revenue) %></td>
                  <td class="text-end">UGX <%= formatCurrencyUGX(costPrice) %></td>
                  <td class="text-end">UGX <%= formatCurrencyUGX(totalCost) %></td>
                  <td class="text-end">UGX <%= formatCurrencyUGX(margin) %></td>
                  <td class="text-center">
                    <% if (units === 0) { %>
                      -
                    <% } else { %>
                      <%= totalCost <= revenue ? '✅' : '❌' %>
                    <% } %>
                  </td>
                </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        </div>
      </div>

    </main>
  </body>
</html>
