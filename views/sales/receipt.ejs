<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Receipt | <%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
    <style>
      body {
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f4f6f9;
      }

      .receipt-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .receipt-paper {
        max-width: 420px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 0.5rem;
        padding: 1.75rem 1.5rem;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
      }

      .receipt-brand {
        text-align: center;
        border-bottom: 2px dashed #dee2e6;
        padding-bottom: 1rem;
        margin-bottom: 1.25rem;
      }

      .receipt-brand h1 {
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin: 0 0 0.25rem;
      }

      .receipt-brand p {
        font-size: 0.8rem;
        color: #6c757d;
        margin: 0;
      }

      .receipt-section-title {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6c757d;
        margin-bottom: 0.5rem;
      }

      .receipt-customer p {
        margin: 0 0 0.35rem;
        font-size: 0.9rem;
      }

      .receipt-customer .customer-label {
        font-weight: 600;
        color: #495057;
      }

      .receipt-divider {
        border: none;
        border-top: 1px dashed #dee2e6;
        margin: 1rem 0;
      }

      .receipt-items {
        width: 100%;
        font-size: 0.85rem;
        border-collapse: collapse;
      }

      .receipt-items th {
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6c757d;
        border-bottom: 1px solid #dee2e6;
        padding: 0.4rem 0;
        text-align: left;
      }

      .receipt-items th:last-child,
      .receipt-items td:last-child {
        text-align: right;
      }

      .receipt-items td {
        padding: 0.55rem 0;
        border-bottom: 1px dotted #e9ecef;
        vertical-align: top;
      }

      .receipt-items .item-name {
        font-weight: 500;
      }

      .receipt-items .item-meta {
        font-size: 0.75rem;
        color: #6c757d;
      }

      .receipt-total {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 700;
        font-size: 1rem;
        padding-top: 0.75rem;
      }

      .receipt-footer {
        text-align: center;
        margin-top: 1.25rem;
        padding-top: 1rem;
        border-top: 2px dashed #dee2e6;
        font-size: 0.75rem;
        color: #6c757d;
        line-height: 1.6;
      }

      .receipt-footer p {
        margin: 0;
      }

      .screen-only {
        max-width: 640px;
        margin: 0 auto;
      }

      @media print {
        body {
          background: #fff;
        }

        .screen-only {
          display: none !important;
        }

        .receipt-paper {
          max-width: 100%;
          border: none;
          box-shadow: none;
          border-radius: 0;
          padding: 0;
          margin: 0;
        }

        @page {
          margin: 12mm;
          size: auto;
        }
      }
    </style>
  </head>
  <body>
    <div class="screen-only container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 class="h4 mb-1">Sale Receipt</h1>
          <p class="text-secondary mb-0 small">Sale #<%= sale.id %></p>
        </div>
        <div class="receipt-actions">
          <button onclick="window.print()" class="btn btn-primary btn-sm">Print Receipt</button>
          <a href="/sales" class="btn btn-outline-secondary btn-sm">Back to Sales</a>
        </div>
      </div>
    </div>

    <div class="receipt-paper">
      <div class="receipt-brand">
        <h1>Sales Management System</h1>
        <p>Receipt #<%= sale.id %></p>
      </div>

      <div class="receipt-customer">
        <div class="receipt-section-title">Customer</div>
        <p><span class="customer-label">Name:</span> <%= sale.customer_name %></p>
        <p><span class="customer-label">Email:</span> <%= sale.customer_email || '—' %></p>
        <p><span class="customer-label">Address:</span> <%= sale.customer_address || '—' %></p>
      </div>

      <hr class="receipt-divider">

      <div class="receipt-section-title">Products Purchased</div>
      <table class="receipt-items">
        <thead>
          <tr>
            <th>Item</th>
            <th>Qty</th>
            <th>Amount</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach((item) => { %>
            <tr>
              <td>
                <div class="item-name"><%= item.product_name %></div>
                <div class="item-meta">
                  UGX <%= formatCurrencyUGX(item.unit_price) %> each
                  <% if (item.sku) { %> &middot; <%= item.sku %><% } %>
                </div>
              </td>
              <td><%= item.quantity %></td>
              <td>UGX <%= formatCurrencyUGX(item.total_price) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>

      <div class="receipt-total">
        <span>Total</span>
        <span>UGX <%= formatCurrencyUGX(sale.total_amount) %></span>
      </div>

      <div class="receipt-footer">
        <p>This receipt is computer generated.</p>
        <p>Thank you for purchasing with us.</p>
        <p><%= new Date(sale.created_at).toLocaleString() %></p>
      </div>
    </div>
  </body>
</html>
