<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Receipt | <%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
  </head>
  <body class="bg-light">
    <main class="container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 class="h3 mb-0">Receipt</h1>
          <p class="text-secondary mb-0">Sale #<%= sale.id %> • <%= new Date(sale.created_at).toLocaleString() %></p>
        </div>
        <button onclick="window.print()" class="btn btn-primary">Print Receipt</button>
      </div>

      <div class="bg-white border rounded p-4 mb-4">
        <h2 class="h5">Sale details</h2>
        <dl class="row mb-0">
          <dt class="col-sm-3">Salesperson</dt>
          <dd class="col-sm-9"><%= sale.user_name || 'System' %></dd>

          <dt class="col-sm-3">Customer</dt>
          <dd class="col-sm-9"><%= sale.customer_name %></dd>

          <dt class="col-sm-3">Total</dt>
          <dd class="col-sm-9">UGX <%= formatCurrencyUGX(sale.total_amount) %></dd>

          <dt class="col-sm-3">Status</dt>
          <dd class="col-sm-9"><%= sale.status %></dd>
        </dl>
      </div>

      <div class="bg-white border rounded p-4 mb-4">
        <h2 class="h5">Products sold</h2>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Product</th>
                <th>SKU</th>
                <th>Unit Price</th>
                <th>Quantity</th>
                <th>Line Total</th>
              </tr>
            </thead>
            <tbody>
              <% items.forEach((item) => { %>
                <tr>
                  <td><%= item.product_name %></td>
                  <td><%= item.sku || '-' %></td>
                  <td>UGX <%= formatCurrencyUGX(item.unit_price) %></td>
                  <td><%= formatNumber(item.quantity) %></td>
                  <td>UGX <%= formatCurrencyUGX(item.total_price) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <a href="/sales" class="btn btn-outline-secondary">Back to Sales</a>
    </main>
  </body>
</html>
