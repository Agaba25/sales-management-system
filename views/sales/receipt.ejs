<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%- include('../partials/google-analytics') %>
    <title>Receipt | <%= title %> | <%= appName %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/brand.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <style>
      body {
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f4f6f9;
      }

      .receipt-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
      }

      .receipt-paper {
        max-width: 480px;
        margin: 0 auto;
        background: #fff;
        border: 1px solid #dee2e6;
        border-radius: 0.5rem;
        padding: 1.75rem 1.5rem;
        box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
      }

      .receipt-brand {
        text-align: center;
        border-bottom: 2px dashed #dee2e6;
        padding-bottom: 1rem;
        margin-bottom: 1.25rem;
      }

      .receipt-section-title {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #6c757d;
        margin-bottom: 0.5rem;
      }

      .receipt-customer p {
        margin: 0 0 0.35rem;
        font-size: 0.9rem;
      }

      .receipt-customer .customer-label {
        font-weight: 600;
        color: #495057;
      }

      .receipt-divider {
        border: none;
        border-top: 1px dashed #dee2e6;
        margin: 1rem 0;
      }

      .receipt-items {
        width: 100%;
        font-size: 0.82rem;
        border-collapse: collapse;
        table-layout: fixed;
      }

      .receipt-items th {
        font-size: 0.68rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #6c757d;
        border-bottom: 1.5px solid #dee2e6;
        padding: 0.45rem 0.25rem;
        text-align: left;
      }

      .receipt-items th.col-units,
      .receipt-items th.col-qty,
      .receipt-items th.col-amount,
      .receipt-items td.col-units,
      .receipt-items td.col-qty,
      .receipt-items td.col-amount {
        text-align: right;
      }

      .receipt-items th.col-qty,
      .receipt-items td.col-qty {
        text-align: center;
      }

      .receipt-items td {
        padding: 0.5rem 0.25rem;
        border-bottom: 1px dotted #e9ecef;
        vertical-align: top;
        word-wrap: break-word;
      }

      .receipt-items .col-item {
        width: 38%;
      }

      .receipt-items .col-units {
        width: 22%;
      }

      .receipt-items .col-qty {
        width: 14%;
      }

      .receipt-items .col-amount {
        width: 26%;
      }

      .receipt-items .item-name {
        font-weight: 500;
        line-height: 1.35;
      }

      .receipt-items tr.receipt-grand-total td {
        border-top: 1.5px solid #343a40;
        border-bottom: none;
        padding-top: 0.75rem;
        font-weight: 700;
        font-size: 0.9rem;
        color: #212529;
      }

      .receipt-items tr.receipt-grand-total td.col-label {
        text-align: right;
        padding-right: 0.5rem;
      }

      .receipt-footer {
        text-align: center;
        margin-top: 1.25rem;
        padding-top: 1rem;
        border-top: 2px dashed #dee2e6;
        font-size: 0.75rem;
        color: #6c757d;
        line-height: 1.6;
      }

      .receipt-footer p {
        margin: 0;
      }

      .screen-only {
        max-width: 640px;
        margin: 0 auto;
      }

      .screen-only .dashboard-nav {
        margin-bottom: 1rem;
      }

      @media print {
        body {
          background: #fff;
        }

        .screen-only {
          display: none !important;
        }

        .receipt-paper {
          max-width: 100%;
          border: none;
          box-shadow: none;
          border-radius: 0;
          padding: 0;
          margin: 0;
        }

        @page {
          margin: 12mm;
          size: auto;
        }
      }
    </style>
  </head>
  <body>
    <div class="screen-only">
      <%- include('../partials/app-navbar', { navLinks: [{ href: '/sales', label: 'Sales', icon: 'bi-receipt', btnClass: 'btn-outline-primary btn-sm' }] }) %>
    </div>
    <div class="screen-only container py-4">
      <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
          <h1 class="h4 mb-1">Sale Receipt</h1>
          <p class="text-secondary mb-0 small">Sale #<%= sale.id %></p>
        </div>
        <div class="receipt-actions">
          <button onclick="window.print()" class="btn btn-primary btn-sm">Print Receipt</button>
          <a href="/sales" class="btn btn-outline-secondary btn-sm">Back to Sales</a>
        </div>
      </div>
    </div>

    <div class="receipt-paper">
      <div class="receipt-brand">
        <img src="/images/mskitech-logo.png" alt="<%= appName %>" class="receipt-logo">
        <%- include('../partials/brand-contact', { contactVariant: 'center' }) %>
        <p class="receipt-number">Receipt #<%= sale.id %></p>
      </div>

      <div class="receipt-customer">
        <div class="receipt-section-title">Customer</div>
        <p><span class="customer-label">Name:</span> <%= sale.customer_name %></p>
        <p><span class="customer-label">Email:</span> <%= sale.customer_email || '—' %></p>
        <p><span class="customer-label">Address:</span> <%= sale.customer_address || '—' %></p>
      </div>

      <hr class="receipt-divider">

      <div class="receipt-section-title">Products Purchased</div>
      <table class="receipt-items">
        <thead>
          <tr>
            <th class="col-item">Item</th>
            <th class="col-units">Unit Price</th>
            <th class="col-qty">QTY</th>
            <th class="col-amount">Amount</th>
          </tr>
        </thead>
        <tbody>
          <% items.forEach((item) => { %>
            <tr>
              <td class="col-item">
                <div class="item-name"><%= item.product_name %></div>
              </td>
              <td class="col-units">UGX <%= formatCurrencyUGX(item.unit_price) %></td>
              <td class="col-qty"><%= item.quantity %></td>
              <td class="col-amount">UGX <%= formatCurrencyUGX(item.total_price) %></td>
            </tr>
          <% }) %>
          <tr class="receipt-grand-total">
            <td class="col-label" colspan="3">Grand Total</td>
            <td class="col-amount">UGX <%= formatCurrencyUGX(sale.total_amount) %></td>
          </tr>
        </tbody>
      </table>

      <div class="receipt-footer">
        <p>This receipt is computer generated.</p>
        <p>Thank you for purchasing with MSKiTECH.</p>
        <p><%= new Date(sale.created_at).toLocaleString() %></p>
      </div>
    </div>
  </body>
</html>
