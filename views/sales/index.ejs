<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%- include('../partials/google-analytics') %>
    <title><%= title %> | <%= appName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/brand.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/app-pages.css">
  </head>
  <body class="dashboard-page">
    <% const navLinks = currentUser.role === 'SALESPERSON'
      ? [{ href: '/sales/new', label: 'New Sale', icon: 'bi-cart-plus', btnClass: 'btn-success btn-sm' }]
      : []; %>
    <%- include('../partials/app-navbar', { navLinks }) %>

    <main class="app-page-main">
      <div class="container">
        <div class="dashboard-back">
          <button type="button" class="btn btn-outline-secondary btn-sm" onclick="history.back()">
            <i class="bi bi-arrow-left me-1"></i>Back
          </button>
        </div>

        <% const totalRevenue = sales.reduce((sum, s) => sum + Number(s.total_amount || 0), 0);
           const totalItems = sales.reduce((sum, s) => sum + Number(s.item_count || 0), 0);
           const isOwnSales = currentUser.role === 'SALESPERSON';
        %>

        <div class="page-hero">
          <span class="page-hero-badge"><i class="bi bi-receipt"></i> Transactions</span>
          <h1><%= isOwnSales ? 'My Sales' : 'Sales' %></h1>
          <p>
            <% if (isOwnSales) { %>
              View your recorded transactions, totals, and download receipts for each sale.
            <% } else { %>
              Monitor all team sales — track revenue, items sold, and access receipts.
            <% } %>
          </p>
        </div>

        <% if (errorMessages && errorMessages.length) { %>
          <div class="alert alert-danger"><%= errorMessages[0] %></div>
        <% } %>
        <% if (successMessages && successMessages.length) { %>
          <div class="alert alert-success"><%= successMessages[0] %></div>
        <% } %>

        <div class="row g-3 insight-grid">
          <div class="col-6 col-lg-4">
            <div class="insight-card">
              <p class="insight-card-label">Total Sales</p>
              <p class="insight-card-value"><%= sales.length %></p>
              <p class="insight-card-hint"><%= isOwnSales ? 'Your transactions' : 'All transactions' %></p>
            </div>
          </div>
          <div class="col-6 col-lg-4">
            <div class="insight-card">
              <p class="insight-card-label">Revenue</p>
              <p class="insight-card-value" style="font-size:1.15rem">UGX <%= formatCurrencyUGX(totalRevenue) %></p>
              <p class="insight-card-hint">Combined sale value</p>
            </div>
          </div>
          <div class="col-12 col-lg-4">
            <div class="insight-card">
              <p class="insight-card-label">Items Sold</p>
              <p class="insight-card-value"><%= totalItems %></p>
              <p class="insight-card-hint">Total units across sales</p>
            </div>
          </div>
        </div>

        <% if (currentUser.role === 'SALESPERSON') { %>
          <div class="filter-panel">
            <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-0">
              <p class="filter-panel-label mb-0">Quick Action</p>
              <a href="/sales/new" class="btn btn-success btn-sm">
                <i class="bi bi-cart-plus me-1"></i>Record New Sale
              </a>
            </div>
          </div>
        <% } %>

        <div class="data-card">
          <div class="data-card-header">
            <h2 class="data-card-title">
              <i class="bi bi-list-ul me-2 text-secondary"></i>Sales History
            </h2>
            <span class="text-muted small"><%= sales.length %> record<%= sales.length === 1 ? '' : 's' %></span>
          </div>
          <div class="table-responsive">
            <table class="table dashboard-table mb-0">
              <thead>
                <tr>
                  <th>Sale #</th>
                  <th>Customer</th>
                  <% if (!isOwnSales) { %><th>Salesperson</th><% } %>
                  <th class="text-center">Items</th>
                  <th class="text-end">Total</th>
                  <th>Date</th>
                  <th class="text-end">Receipt</th>
                </tr>
              </thead>
              <tbody>
                <% if (sales.length === 0) { %>
                  <tr>
                    <td colspan="<%= isOwnSales ? 6 : 7 %>" class="dashboard-empty py-4">
                      No sales recorded yet.
                      <% if (isOwnSales) { %>
                        <a href="/sales/new" class="d-block mt-2">Create your first sale</a>
                      <% } %>
                    </td>
                  </tr>
                <% } %>

                <% sales.forEach((sale) => { %>
                  <tr>
                    <td><span class="entity-tag">#<%= sale.id %></span></td>
                    <td class="product-name-cell"><%= sale.customer_name %></td>
                    <% if (!isOwnSales) { %>
                      <td><%= sale.user_name || 'System' %></td>
                    <% } %>
                    <td class="text-center"><%= sale.item_count %></td>
                    <td class="text-end price-cell">UGX <%= formatCurrencyUGX(sale.total_amount) %></td>
                    <td class="text-muted"><%= new Date(sale.created_at).toLocaleString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></td>
                    <td class="text-end">
                      <a href="/sales/<%= sale.id %>/receipt" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-receipt"></i> View
                      </a>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </main>

    <%- include('../partials/app-footer') %>
  </body>
</html>
