<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand" href="/">Sales Management System</a>
        <div class="d-flex align-items-center gap-3">
          <a href="/sales/new" class="btn btn-primary btn-sm">New Sale</a>
          <a href="/inventory" class="btn btn-outline-primary btn-sm">Inventory</a>
          <a href="/products" class="btn btn-outline-secondary btn-sm">Products</a>
          <a href="/customers" class="btn btn-outline-secondary btn-sm">Customers</a>
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
        <h1 class="h3 mb-0">Sales</h1>
      </div>

      <% if (errorMessages && errorMessages.length) { %>
        <div class="alert alert-danger"><%= errorMessages[0] %></div>
      <% } %>
      <% if (successMessages && successMessages.length) { %>
        <div class="alert alert-success"><%= successMessages[0] %></div>
      <% } %>

      <div class="table-responsive bg-white border rounded">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Customer</th>
              <th>Salesperson</th>
              <th>Items</th>
              <th>Total</th>
              <th>Date</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% if (sales.length === 0) { %>
              <tr>
                <td colspan="7" class="text-center text-secondary py-4">No sales recorded.</td>
              </tr>
            <% } %>

            <% sales.forEach((sale) => { %>
              <tr>
                <td><%= sale.id %></td>
                <td><%= sale.customer_name %></td>
                <td><%= sale.user_name || 'System' %></td>
                <td><%= sale.item_count %></td>
                <td>UGX <%= formatCurrencyUGX(sale.total_amount) %></td>
                <td><%= new Date(sale.created_at).toLocaleString() %></td>
                <td>
                  <a href="/sales/<%= sale.id %>/receipt" class="btn btn-sm btn-outline-primary">Receipt</a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </body>
</html>
