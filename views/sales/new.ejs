<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/brand.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    <link rel="stylesheet" href="/css/pos.css">
  </head>
  <body class="dashboard-page pos-page">
    <% const navLinks = [{ href: '/sales', label: 'Sales', icon: 'bi-receipt', btnClass: 'btn-outline-primary btn-sm' }]; %>
    <%- include('../partials/app-navbar', { navLinks }) %>

    <header class="pos-header">
      <div class="container pos-header-inner">
        <div>
          <h1 class="pos-title">
            <i class="bi bi-lightning-charge-fill text-success me-1"></i> Quick Sale
            <small>Search products, pick customer, complete in seconds</small>
          </h1>
        </div>
        <a href="/sales" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-arrow-left me-1"></i> Back to sales
        </a>
      </div>
    </header>

    <main class="pos-main">
      <div class="container">
        <% if (errorMessages && errorMessages.length) { %>
          <% errorMessages.forEach((message) => { %>
            <div class="alert alert-danger"><%= message %></div>
          <% }) %>
        <% } %>

        <form action="/sales" method="POST" id="sale-form">
          <input type="hidden" name="customer_id" id="customer-id-field" value="">
          <div id="sale-form-fields"></div>

          <div class="pos-layout">
            <!-- Products panel -->
            <div class="pos-panel">
              <div class="pos-panel-header">
                <div class="pos-search-wrap">
                  <i class="bi bi-search pos-search-icon"></i>
                  <input
                    type="search"
                    id="product-search"
                    class="form-control"
                    placeholder="Search by product name, SKU, or category..."
                    autocomplete="off"
                    autofocus
                  >
                </div>
                <% if (categories && categories.length) { %>
                  <div class="pos-category-chips" id="category-chips">
                    <button type="button" class="pos-chip active" data-category="">All</button>
                    <% categories.forEach((cat) => { %>
                      <button type="button" class="pos-chip" data-category="<%= cat.name %>"><%= cat.name %></button>
                    <% }) %>
                  </div>
                <% } %>
              </div>
              <div class="pos-panel-body">
                <div class="pos-loading" id="product-loading">
                  <div class="spinner-border text-primary" role="status"></div>
                  <p class="mb-0 mt-2 small">Loading products...</p>
                </div>
                <div class="pos-product-grid" id="product-grid"></div>
              </div>
            </div>

            <!-- Cart panel -->
            <div class="pos-panel pos-cart">
              <div class="pos-panel-header">
                <h2 class="h6 mb-0"><i class="bi bi-person me-1"></i> Customer</h2>
              </div>
              <div class="pos-panel-body">
                <div class="pos-customer-section">
                  <div id="customer-selected" class="pos-customer-selected" style="display:none;">
                    <div>
                      <div class="name" id="customer-selected-name"></div>
                      <div class="meta" id="customer-selected-meta"></div>
                    </div>
                    <button type="button" id="clear-customer" class="btn btn-sm btn-outline-secondary">Change</button>
                  </div>

                  <div class="pos-search-wrap">
                    <i class="bi bi-person-search pos-search-icon"></i>
                    <input
                      type="search"
                      id="customer-search"
                      class="form-control"
                      placeholder="Search customer by name, phone, or email..."
                      autocomplete="off"
                    >
                    <div class="pos-dropdown" id="customer-dropdown"></div>
                  </div>

                  <div class="d-flex justify-content-between align-items-center mt-2">
                    <span class="small text-secondary">Recent customers</span>
                    <button type="button" id="quick-add-btn" class="btn btn-link btn-sm p-0">
                      <i class="bi bi-person-plus"></i> Quick add
                    </button>
                  </div>
                  <div class="pos-recent-customers" id="recent-customers">
                    <% if (recentCustomers && recentCustomers.length) { %>
                      <% recentCustomers.forEach((customer) => { %>
                        <button
                          type="button"
                          class="pos-recent-btn"
                          data-customer-id="<%= customer.id %>"
                          data-customer-name="<%= customer.name %>"
                          data-customer-phone="<%= customer.phone || '' %>"
                          data-customer-email="<%= customer.email || '' %>"
                        ><%= customer.name %></button>
                      <% }) %>
                    <% } else { %>
                      <span class="small text-secondary">No recent sales yet</span>
                    <% } %>
                  </div>
                </div>

                <h2 class="h6 mb-2"><i class="bi bi-cart3 me-1"></i> Cart</h2>
                <div id="cart-empty" class="pos-empty py-3">
                  <i class="bi bi-cart"></i>
                  <p class="mb-0 small">Click a product to add it here</p>
                </div>
                <div class="pos-cart-items" id="cart-items"></div>

                <div class="pos-cart-total">
                  <div class="pos-cart-total-label">Total</div>
                  <div class="pos-cart-total-value">UGX <span id="cart-total">0.00</span></div>
                  <button type="submit" id="complete-sale" class="btn btn-success pos-complete-btn" disabled>
                    <i class="bi bi-check-circle me-1"></i> Complete Sale
                  </button>
                  <p class="pos-keyboard-hint mb-0">
                    <kbd>F2</kbd> products · <kbd>F3</kbd> customer · <kbd>Enter</kbd> add first match
                  </p>
                </div>
              </div>
            </div>
          </div>
        </form>
      </div>
    </main>

    <!-- Quick add customer modal -->
    <div class="modal fade" id="quickAddCustomerModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title"><i class="bi bi-person-plus me-1"></i> Quick Add Customer</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <form id="quick-add-form">
            <div class="modal-body">
              <div class="alert alert-danger py-2 small" id="quick-add-error" style="display:none;"></div>
              <div class="mb-3">
                <label for="quick-add-name" class="form-label">Name <span class="text-danger">*</span></label>
                <input type="text" id="quick-add-name" class="form-control" required placeholder="Customer name">
              </div>
              <div class="mb-0">
                <label for="quick-add-phone" class="form-label">Phone <span class="text-secondary">(optional)</span></label>
                <input type="text" id="quick-add-phone" class="form-control" placeholder="e.g. 0772123456">
              </div>
              <p class="form-text small mb-0 mt-2">Only name is required. You can add more details later from Customers.</p>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-primary btn-sm">Add &amp; Select</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/pos-sale.js"></script>
  </body>
</html>
