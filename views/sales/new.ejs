<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | <%= appName %></title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
    <link rel="stylesheet" href="/css/brand.css">
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <%- include('../partials/brand-mark') %>
        <div class="d-flex align-items-center gap-3">
          <a href="/sales" class="btn btn-outline-primary btn-sm">Sales</a>
          <a href="/inventory" class="btn btn-outline-secondary btn-sm">Inventory</a>
          <a href="/products" class="btn btn-outline-secondary btn-sm">Products</a>
          <a href="/customers" class="btn btn-outline-secondary btn-sm">Customers</a>
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <div>
          <h1 class="h3 mb-1">New Sale</h1>
          <p class="text-secondary mb-0">Select a customer, choose products, and save the sale.</p>
        </div>
      </div>

      <% if (errorMessages && errorMessages.length) { %>
        <div class="alert alert-danger"><%= errorMessages[0] %></div>
      <% } %>

      <form action="/sales" method="POST" id="sale-form">
        <div class="bg-white border rounded p-4 mb-4">
          <div class="row g-3">
            <div class="col-md-6">
              <label for="customer_id" class="form-label">Customer</label>
              <select id="customer_id" name="customer_id" class="form-select" required>
                <option value="">Choose a customer</option>
                <% customers.forEach((customer) => { %>
                  <option value="<%= customer.id %>"><%= customer.name %> <% if (customer.email) { %> - <%= customer.email %><% } %></option>
                <% }) %>
              </select>
              <div class="form-text">
                <a href="/customers/new">Add a customer</a> if the buyer is not listed.
              </div>
            </div>
          </div>
        </div>

        <div class="bg-white border rounded p-4 mb-4">
          <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 mb-0">Products</h2>
            <% if (products.length > 0) { %>
              <button type="button" id="add-product" class="btn btn-sm btn-outline-primary">Add product</button>
            <% } %>
          </div>

          <% if (products.length === 0) { %>
            <div class="alert alert-warning mb-0">No active products are currently available for sale.</div>
          <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Product</th>
                  <th>Unit Price</th>
                  <th>Quantity</th>
                  <th>Line Total</th>
                  <th></th>
                </tr>
              </thead>
              <tbody id="sale-items">
                <tr class="sale-item-row">
                  <td>
                    <select name="product_id[]" class="form-select product-select" required>
                      <option value="">Select product</option>
                      <% products.forEach((product) => { %>
                        <option value="<%= product.id %>" data-unit-price="<%= product.unit_price %>" data-stock="<%= product.quantity %>"><%= product.name %> (<%= product.sku %>) - <%= product.quantity %> in stock</option>
                      <% }) %>
                    </select>
                  </td>
                  <td>
                    <input type="text" name="unit_price[]" class="form-control form-control-sm unit-price" value="0.00" readonly>
                  </td>
                  <td>
                    <input type="number" name="quantity[]" min="1" class="form-control form-control-sm quantity-input" value="1" required>
                  </td>
                  <td>
                    <input type="text" class="form-control form-control-sm line-total" value="0.00" readonly>
                  </td>
                  <td>
                    <button type="button" class="btn btn-outline-danger btn-sm remove-row">Remove</button>
                  </td>
                </tr>
              </tbody>
            </table>
          </div>
          <% } %>

          <div class="d-flex justify-content-end align-items-center gap-3 mt-3">
            <div class="text-end">
              <p class="mb-1 text-secondary">Total</p>
              <h4 class="mb-0">UGX <span id="sale-total">0.00</span></h4>
            </div>
          </div>
        </div>

        <div class="d-flex gap-2">
          <button type="submit" class="btn btn-primary" <%= products.length === 0 ? 'disabled' : '' %>>Save Sale</button>
          <a href="/sales" class="btn btn-outline-secondary">Cancel</a>
        </div>
      </form>
    </main>

    <% if (products.length > 0) { %>
    <script>
      const products = <%- JSON.stringify(products) %>;
      const saleItemsBody = document.getElementById("sale-items");
      const addProductButton = document.getElementById("add-product");
      const saleTotalElement = document.getElementById("sale-total");

      const formatCurrency = (value) => {
        const number = Number(String(value).replace(/,/g, "")) || 0;
        return new Intl.NumberFormat("en-US", { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(number);
      };

      const parseCurrency = (value) => Number(String(value).replace(/,/g, "")) || 0;

      const updateLine = (row) => {
        const productSelect = row.querySelector(".product-select");
        const priceInput = row.querySelector(".unit-price");
        const quantityInput = row.querySelector(".quantity-input");
        const lineTotalInput = row.querySelector(".line-total");

        const selectedOption = productSelect.selectedOptions[0];
        const unitPrice = selectedOption ? Number(selectedOption.dataset.unitPrice || 0) : 0;
        const stock = selectedOption ? Number(selectedOption.dataset.stock || 0) : 0;
        if (stock > 0) {
          quantityInput.max = stock;
        }
        const quantity = Number(quantityInput.value) || 0;
        const lineTotal = unitPrice * quantity;

        priceInput.value = formatCurrency(unitPrice);
        lineTotalInput.value = formatCurrency(lineTotal);
        updateTotal();
      };

      const updateTotal = () => {
        const lineTotals = [...document.querySelectorAll(".line-total")].map((input) => parseCurrency(input.value));
        const total = lineTotals.reduce((sum, value) => sum + value, 0);
        saleTotalElement.textContent = formatCurrency(total);
      };

      const attachRowEvents = (row) => {
        const productSelect = row.querySelector(".product-select");
        const quantityInput = row.querySelector(".quantity-input");
        const removeButton = row.querySelector(".remove-row");

        productSelect.addEventListener("change", () => updateLine(row));
        quantityInput.addEventListener("input", () => updateLine(row));
        removeButton.addEventListener("click", () => {
          if (saleItemsBody.children.length > 1) {
            row.remove();
            updateTotal();
          }
        });
      };

      const createSaleRow = () => {
        const row = document.querySelector(".sale-item-row").cloneNode(true);
        row.querySelectorAll("input").forEach((field) => {
          if (field.type === "number") {
            field.value = 1;
          } else {
            field.value = "0.00";
          }
        });
        row.querySelector(".product-select").selectedIndex = 0;
        attachRowEvents(row);
        return row;
      };

      addProductButton.addEventListener("click", () => {
        saleItemsBody.appendChild(createSaleRow());
      });

      document.querySelectorAll(".sale-item-row").forEach((row) => attachRowEvents(row));
      updateTotal();
    </script>
    <% } %>
  </body>
</html>
