<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand" href="/">Sales Management System</a>
        <div class="d-flex align-items-center gap-3">
          <a href="/inventory" class="btn btn-outline-primary btn-sm">Inventory</a>
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <h1 class="h3 mb-3">Inventory History</h1>

      <% if (errorMessages && errorMessages.length) { %>
        <div class="alert alert-danger"><%= errorMessages[0] %></div>
      <% } %>

      <div class="table-responsive bg-white border rounded">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Date</th>
              <th>Product</th>
              <th>Type</th>
              <th>Quantity</th>
              <th>Previous</th>
              <th>New</th>
              <th>Recorded By</th>
              <th>Reason</th>
            </tr>
          </thead>
          <tbody>
            <% if (movements.length === 0) { %>
              <tr>
                <td colspan="8" class="text-center text-secondary py-4">No stock movements recorded.</td>
              </tr>
            <% } %>

            <% movements.forEach((movement) => { %>
              <tr>
                <td><%= new Date(movement.created_at).toLocaleString() %></td>
                <td><%= movement.product_name %> <span class="text-secondary small">(<%= movement.sku %>)</span></td>
                <td>
                  <% if (movement.movement_type === 'IN') { %>
                    <span class="badge text-bg-success">Stock In</span>
                  <% } else { %>
                    <span class="badge text-bg-danger">Stock Out</span>
                  <% } %>
                </td>
                <td><%= formatNumber(movement.quantity) %></td>
                <td><%= formatNumber(movement.previous_quantity) %></td>
                <td><%= formatNumber(movement.new_quantity) %></td>
                <td><%= movement.user_name || 'System' %></td>
                <td><%= movement.reason || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </body>
</html>
