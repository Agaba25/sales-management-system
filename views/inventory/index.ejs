<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
  </head>
  <body class="bg-light">
    <nav class="navbar navbar-expand-lg bg-white border-bottom">
      <div class="container">
        <a class="navbar-brand" href="/">Sales Management System</a>
        <div class="d-flex align-items-center gap-3">
          <a href="/products" class="btn btn-outline-primary btn-sm">Products</a>
          <a href="/inventory/history" class="btn btn-outline-secondary btn-sm">History</a>
          <span class="text-secondary small"><%= currentUser.name %> | <%= currentUser.role %></span>
          <form action="/auth/logout" method="POST" class="mb-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Logout</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="container py-4">
      <div class="d-flex flex-wrap gap-2 align-items-center justify-content-between mb-3">
        <h1 class="h3 mb-0">Inventory</h1>
        <span class="badge text-bg-warning"><%= formatNumber(lowStockProducts.length) %> Low Stock Alerts</span>
      </div>

      <% if (errorMessages && errorMessages.length) { %>
        <div class="alert alert-danger"><%= errorMessages[0] %></div>
      <% } %>
      <% if (successMessages && successMessages.length) { %>
        <div class="alert alert-success"><%= successMessages[0] %></div>
      <% } %>

      <% if (lowStockProducts.length > 0) { %>
        <div class="alert alert-warning">
          <strong>Low stock:</strong>
          <%= lowStockProducts.map((product) => `${product.name} (${formatNumber(product.quantity)})`).join(", ") %>
        </div>
      <% } %>

      <form action="/inventory" method="GET" class="row g-2 mb-3">
        <div class="col-md-10">
          <input
            type="search"
            name="search"
            value="<%= search %>"
            class="form-control"
            placeholder="Search inventory by product, SKU, or category"
          >
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-outline-primary w-100">Search</button>
        </div>
      </form>

      <div class="table-responsive bg-white border rounded">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Product</th>
              <th>SKU</th>
              <th>Category</th>
              <th>Stock</th>
              <th>Reorder Level</th>
              <th>Status</th>
              <th class="text-end">Stock Movement</th>
            </tr>
          </thead>
          <tbody>
            <% if (inventory.length === 0) { %>
              <tr>
                <td colspan="7" class="text-center text-secondary py-4">No inventory found.</td>
              </tr>
            <% } %>

            <% inventory.forEach((item) => { %>
              <tr>
                <td><%= item.name %></td>
                <td><%= item.sku %></td>
                <td><%= item.category_name || 'Uncategorized' %></td>
                <td><%= formatNumber(item.quantity) %></td>
                <td><%= formatNumber(item.reorder_level) %></td>
                <td>
                  <% if (item.quantity === 0) { %>
                    <span class="badge text-bg-danger">Out of Stock</span>
                  <% } else if (item.quantity <= item.reorder_level) { %>
                    <span class="badge text-bg-warning">Low Stock</span>
                  <% } else { %>
                    <span class="badge text-bg-success">Available</span>
                  <% } %>
                </td>
                <td class="text-end">
                  <% if (currentUser.role === 'CEO' || currentUser.role === 'MANAGER') { %>
                    <form action="/inventory/<%= item.id %>/stock-in" method="POST" class="d-inline-flex gap-1 mb-1">
                      <input type="number" name="quantity" min="1" class="form-control form-control-sm" style="width: 90px;" placeholder="Qty" required>
                      <input type="text" name="reason" class="form-control form-control-sm" style="width: 130px;" placeholder="Reason">
                      <button type="submit" class="btn btn-success btn-sm">Stock In</button>
                    </form>
                    <form action="/inventory/<%= item.id %>/stock-out" method="POST" class="d-inline-flex gap-1">
                      <input type="number" name="quantity" min="1" class="form-control form-control-sm" style="width: 90px;" placeholder="Qty" required>
                      <input type="text" name="reason" class="form-control form-control-sm" style="width: 130px;" placeholder="Reason">
                      <button type="submit" class="btn btn-danger btn-sm">Stock Out</button>
                    </form>
                  <% } else { %>
                    <span class="text-secondary small">View only</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </main>
  </body>
</html>
