<nav class="navbar navbar-expand-lg dashboard-nav">
  <div class="container">
    <%- include('brand-mark') %>
    <div class="d-flex align-items-center gap-2 gap-md-3">
      <a href="/" class="btn btn-outline-secondary btn-sm" title="Dashboard">
        <i class="bi bi-house"></i><span class="d-none d-sm-inline ms-1">Dashboard</span>
      </a>
      <% if (typeof navLinks !== 'undefined' && navLinks && navLinks.length) { %>
        <% navLinks.forEach((link) => { %>
          <a href="<%= link.href %>"
             class="btn <%= link.btnClass || 'btn-outline-secondary btn-sm' %> d-none d-sm-inline-flex"
             <% if (link.title) { %>title="<%= link.title %>"<% } %>>
            <% if (link.icon) { %><i class="bi <%= link.icon %> me-1"></i><% } %><%= link.label %>
          </a>
        <% }) %>
      <% } %>
      <% if (currentUser) { %>
        <div class="user-pill">
          <span class="user-avatar"><%= currentUser.name.charAt(0).toUpperCase() %></span>
          <span>
            <span class="user-name d-block"><%= currentUser.name %></span>
            <span class="user-role"><%= currentUser.role %></span>
          </span>
        </div>
        <form action="/auth/logout" method="POST" class="mb-0">
          <button type="submit" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
          </button>
        </form>
      <% } %>
    </div>
  </div>
</nav>
