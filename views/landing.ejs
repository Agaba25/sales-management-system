<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
      <div class="container">
        <a class="navbar-brand fw-bold text-primary" href="/">Sales Management System</a>
        <div class="d-flex align-items-center gap-2">
          <a href="/auth/login" class="btn btn-outline-primary btn-sm">Login</a>
        </div>
      </div>
    </nav>

    <main>
      <section class="hero section-pt pb-5">
        <div class="container py-5">
          <div class="row align-items-center gy-5">
            <div class="col-lg-6 text-white">
              <span class="badge bg-white text-primary mb-3">Smart sales, smarter teams</span>
              <h1 class="display-5 fw-bold">Modern sales management for every role.</h1>
              <p class="lead text-white-75 mb-4">
                Empower your CEO, managers, and sales team with inventory tracking, customer insights, role-based dashboards, and fast order processing.
              </p>
              <div class="d-flex flex-column flex-sm-row gap-3">
                <a href="/auth/login" class="btn btn-lg btn-light btn-shadow">Get started</a>
                <a href="#features" class="btn btn-lg btn-outline-light">See features</a>
              </div>
            </div>

            <div class="col-lg-6">
              <div class="hero-card p-4 rounded-4 shadow-lg bg-white border">
                <div class="d-flex align-items-center justify-content-between mb-4">
                  <div>
                    <p class="text-uppercase text-muted mb-1 small">Sales Management</p>
                    <h3 class="h5 mb-0">Everything in one place</h3>
                  </div>
                  <span class="badge bg-secondary">Live preview</span>
                </div>

                <div class="row g-3">
                  <div class="col-6">
                    <div class="feature-preview rounded-3 p-3 bg-light">
                      <div class="text-muted small">Inventory</div>
                      <div class="fw-semibold mt-2">Stock alerts</div>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="feature-preview rounded-3 p-3 bg-light">
                      <div class="text-muted small">Products</div>
                      <div class="fw-semibold mt-2">Catalog manager</div>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="feature-preview rounded-3 p-3 bg-light">
                      <div class="text-muted small">Sales</div>
                      <div class="fw-semibold mt-2">Fast checkout</div>
                    </div>
                  </div>
                  <div class="col-6">
                    <div class="feature-preview rounded-3 p-3 bg-light">
                      <div class="text-muted small">Customers</div>
                      <div class="fw-semibold mt-2">CRM details</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="features" class="container py-5">
        <div class="text-center mb-5">
          <span class="badge bg-primary bg-opacity-10 text-primary mb-2">Features built for teams</span>
          <h2 class="fw-bold">Designed to keep your sales operations aligned</h2>
          <p class="text-secondary mx-auto" style="max-width: 640px;">One platform for product inventory, order tracking, customer management, and dashboards tailored to CEO, Manager, and Salesperson roles.</p>
        </div>

        <div class="row g-4">
          <div class="col-md-6 col-xl-3">
            <div class="feature-card p-4 h-100 rounded-4 shadow-sm border">
              <div class="mb-3 text-primary feature-icon">📦</div>
              <h3 class="h5">Inventory health</h3>
              <p class="text-secondary mb-0">Track stock levels, low inventory, and restock needs in one central dashboard.</p>
            </div>
          </div>
          <div class="col-md-6 col-xl-3">
            <div class="feature-card p-4 h-100 rounded-4 shadow-sm border">
              <div class="mb-3 text-primary feature-icon">💳</div>
              <h3 class="h5">Sales order flow</h3>
              <p class="text-secondary mb-0">Create sales, print receipts, and monitor performance per salesperson.</p>
            </div>
          </div>
          <div class="col-md-6 col-xl-3">
            <div class="feature-card p-4 h-100 rounded-4 shadow-sm border">
              <div class="mb-3 text-primary feature-icon">👥</div>
              <h3 class="h5">Customer care</h3>
              <p class="text-secondary mb-0">Manage customers, record details, and build stronger relationships.</p>
            </div>
          </div>
          <div class="col-md-6 col-xl-3">
            <div class="feature-card p-4 h-100 rounded-4 shadow-sm border">
              <div class="mb-3 text-primary feature-icon">🔐</div>
              <h3 class="h5">Role-based access</h3>
              <p class="text-secondary mb-0">Secure dashboards for CEO, Manager, and Salesperson roles with proper permissions.</p>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white py-5">
        <div class="container">
          <div class="row align-items-center gy-4">
            <div class="col-lg-6">
              <h2 class="fw-bold">Launch your sales workflow with confidence</h2>
              <p class="text-secondary">The Sales Management System is crafted for small teams and growing businesses. It keeps your product catalog, inventory monitoring, sales activity, and dashboard reporting connected and easy to use.</p>
              <ul class="list-unstyled text-secondary mb-0">
                <li class="mb-2">• Secure login and session handling</li>
                <li class="mb-2">• Clean role-aware dashboards</li>
                <li class="mb-2">• Bootstrap-driven responsive design</li>
              </ul>
            </div>
            <div class="col-lg-6">
              <div class="rounded-4 shadow-lg p-4 bg-primary bg-opacity-10">
                <div class="p-4 rounded-4 bg-white border">
                  <h3 class="h5 mb-3">Start with your team</h3>
                  <p class="text-secondary">Login to access the full Sales Management System experience or create your first user in the database seed files.</p>
                  <a href="/auth/login" class="btn btn-primary">Go to Login</a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
