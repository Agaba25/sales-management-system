<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= title %> | Sales Management System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
    >
    <link rel="stylesheet" href="/css/styles.css">
  </head>
  <body>
    <nav class="navbar navbar-expand-lg landing-nav sticky-top">
      <div class="container">
        <a class="navbar-brand fw-bold" href="/">Sales Management System</a>
        <div class="d-flex align-items-center gap-2">
          <a href="/auth/login" class="btn btn-login btn-sm">Login</a>
        </div>
      </div>
    </nav>

    <main>
      <section class="hero">
        <div class="container">
          <div class="row align-items-center gy-5">
            <div class="col-lg-6">
              <div class="hero-eyebrow">
                <span>Smart sales, smarter teams</span>
              </div>
              <h1>Run your entire sales operation from one place.</h1>
              <p class="hero-lead">
                Track inventory, process orders, manage customers, and monitor performance — with role-based dashboards built for CEOs, managers, and sales teams.
              </p>
              <div class="d-flex flex-column flex-sm-row gap-3">
                <a href="/auth/login" class="btn btn-lg hero-cta-primary">Get started</a>
                <a href="#features" class="btn btn-lg hero-cta-secondary">See features</a>
              </div>
            </div>

            <div class="col-lg-6">
              <div class="hero-card">
                <div class="hero-card-header">
                  <div class="d-flex gap-2">
                    <span class="dot" style="background:#ef4444"></span>
                    <span class="dot" style="background:#f59e0b"></span>
                    <span class="dot" style="background:#22c55e"></span>
                  </div>
                  <span class="text-muted small fw-semibold">Dashboard preview</span>
                </div>
                <div class="hero-card-body">
                  <div class="row g-3">
                    <div class="col-6">
                      <div class="stat-tile">
                        <div class="stat-icon">📦</div>
                        <div class="stat-label">Inventory</div>
                        <div class="stat-value">Stock alerts</div>
                      </div>
                    </div>
                    <div class="col-6">
                      <div class="stat-tile">
                        <div class="stat-icon">🏷️</div>
                        <div class="stat-label">Products</div>
                        <div class="stat-value">Catalog manager</div>
                      </div>
                    </div>
                    <div class="col-6">
                      <div class="stat-tile">
                        <div class="stat-icon">💳</div>
                        <div class="stat-label">Sales</div>
                        <div class="stat-value">Fast checkout</div>
                      </div>
                    </div>
                    <div class="col-6">
                      <div class="stat-tile">
                        <div class="stat-icon">👥</div>
                        <div class="stat-label">Customers</div>
                        <div class="stat-value">CRM details</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="features" class="features-section">
        <div class="container">
          <div class="text-center">
            <span class="section-eyebrow">Features built for teams</span>
            <h2>Everything your sales team needs</h2>
            <p class="section-desc">One platform for product inventory, order tracking, customer management, and dashboards tailored to CEO, Manager, and Salesperson roles.</p>
          </div>

          <div class="row g-4">
            <div class="col-md-6 col-xl-3">
              <div class="feature-card">
                <div class="feature-icon-wrap">📦</div>
                <h3>Inventory health</h3>
                <p>Track stock levels, low inventory, and restock needs in one central dashboard.</p>
              </div>
            </div>
            <div class="col-md-6 col-xl-3">
              <div class="feature-card">
                <div class="feature-icon-wrap">💳</div>
                <h3>Sales order flow</h3>
                <p>Create sales, print receipts, and monitor performance per salesperson.</p>
              </div>
            </div>
            <div class="col-md-6 col-xl-3">
              <div class="feature-card">
                <div class="feature-icon-wrap">👥</div>
                <h3>Customer care</h3>
                <p>Manage customers, record details, and build stronger relationships.</p>
              </div>
            </div>
            <div class="col-md-6 col-xl-3">
              <div class="feature-card">
                <div class="feature-icon-wrap">🔐</div>
                <h3>Role-based access</h3>
                <p>Secure dashboards for CEO, Manager, and Salesperson roles with proper permissions.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="cta-section">
        <div class="container">
          <div class="row align-items-center gy-4">
            <div class="col-lg-6">
              <h2>Launch your sales workflow with confidence</h2>
              <p class="text-secondary">Built for small teams and growing businesses — keeping your product catalog, inventory, sales activity, and reporting connected and easy to use.</p>
              <ul class="cta-checklist">
                <li>Secure login and session handling</li>
                <li>Clean role-aware dashboards</li>
                <li>Responsive design on every device</li>
              </ul>
            </div>
            <div class="col-lg-6">
              <div class="cta-card">
                <h3>Start with your team</h3>
                <p>Login to access the full Sales Management System experience, or set up your first users via the database seed files.</p>
                <a href="/auth/login" class="btn">Go to Login</a>
              </div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="landing-footer">
      <strong>Sales Management System</strong> &mdash; Streamline your sales operations.
    </footer>
  </body>
</html>
